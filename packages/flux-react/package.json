{
  "name": "@nop-chaos/flux-react",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./unstable": {
      "types": "./dist/unstable.d.ts",
      "default": "./dist/unstable.js"
    },
    "./default-spacing.css": "./dist/default-spacing.css"
  },
  "dependencies": {
    "@nop-chaos/flux-core": "workspace:*",
    "@nop-chaos/flux-formula": "workspace:*",
    "@nop-chaos/flux-i18n": "workspace:*",
    "@nop-chaos/flux-runtime": "workspace:*",
    "@nop-chaos/ui": "workspace:*",
    "use-sync-external-store": "^1.6.0"
  },
  "peerDependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@nop-chaos/flux-compiler": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/use-sync-external-store": "^1.5.0",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/copy-build-assets.mjs src/default-spacing.css dist/default-spacing.css",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location node_modules/.cache/eslint"
  },
  "description": "React integration layer: hooks, contexts, and renderer orchestration"
}
