{
  "type": "designer-page",
  "treeDocument": {
    "id": "leave-approval",
    "kind": "dingtalk-workflow",
    "name": "请假审批",
    "version": "1.0.0",
    "root": {
      "id": "k001",
      "type": "dt-initiator",
      "data": { "label": "发起人", "type": 0 },
      "child": {
        "id": "k002",
        "type": "dt-approval",
        "data": { "label": "主管审批", "type": 1, "setType": 2, "examineMode": 1 },
        "child": {
          "id": "k003",
          "type": "dt-condition",
          "data": { "label": "条件路由", "type": 4, "mode": "exclusive" },
          "branches": [
            {
              "id": "b1",
              "data": {
                "label": "长期请假",
                "priority": 1,
                "conditionList": [[{ "field": "day", "operator": ">", "value": "7" }]]
              },
              "child": {
                "id": "k004",
                "type": "dt-approval",
                "data": { "label": "CEO审批", "type": 1, "setType": 1, "examineMode": 2 }
              }
            },
            {
              "id": "b2",
              "data": { "label": "短期请假", "priority": 2, "conditionList": [] },
              "child": {
                "id": "k004b",
                "type": "dt-approval",
                "data": { "label": "直接主管审批", "type": 1, "setType": 2, "examineMode": 1 }
              }
            }
          ],
          "child": {
            "id": "k005",
            "type": "dt-cc",
            "data": { "label": "抄送HR", "type": 2 },
            "child": {
              "id": "k006",
              "type": "dt-parallel",
              "data": { "label": "并行处理", "type": 8, "mode": "parallel" },
              "branches": [
                {
                  "id": "b3",
                  "data": { "label": "并行分支1", "priority": 1 },
                  "child": {
                    "id": "k007",
                    "type": "dt-approval",
                    "data": { "label": "人事确认", "type": 1 }
                  }
                },
                {
                  "id": "b4",
                  "data": { "label": "并行分支2", "priority": 2 },
                  "child": {
                    "id": "k008",
                    "type": "dt-subprocess",
                    "data": { "label": "工作交接", "type": 5, "callProcess": "workHandover" }
                  }
                }
              ],
              "child": {
                "id": "k009",
                "type": "dt-end",
                "data": { "label": "结束", "type": -1 }
              }
            }
          }
        }
      }
    }
  },
  "config": {
    "version": "1.0.0",
    "kind": "dingtalk-workflow",
    "documentMode": "tree",
    "treeConfig": {
      "layout": { "direction": "TB", "nodeSpacing": 60, "layerSpacing": 100 },
      "showGatewayNodes": false,
      "showMergeNodes": false,
      "autoLayout": true,
      "chainEdgeType": "dt-chain",
      "branchEdgeType": "dt-branch",
      "mergeEdgeType": "dt-merge"
    },
    "nodeTypes": [
      {
        "id": "dt-initiator",
        "label": "发起人",
        "icon": "user",
        "body": {
          "type": "flex",
          "direction": "column",
          "gap": 4,
          "className": "dt-node-root",
          "data-slot": "dt-node",
          "data-node-variant": "initiator",
          "items": [
            {
              "type": "flex",
              "data-slot": "dt-node-header",
              "items": [
                { "type": "icon", "icon": "user", "data-slot": "dt-node-icon" },
                { "type": "text", "body": "${label}", "data-slot": "dt-node-title" }
              ]
            },
            { "type": "text", "body": "所有人", "data-slot": "dt-node-subtitle" }
          ]
        },
        "appearance": { "minWidth": 200, "minHeight": 80 },
        "tree": { "allowChild": true, "allowBranches": false, "isTerminal": false }
      },
      {
        "id": "dt-approval",
        "label": "审批人",
        "icon": "user-check",
        "body": {
          "type": "flex",
          "direction": "column",
          "gap": 4,
          "className": "dt-node-root",
          "data-slot": "dt-node",
          "data-node-variant": "approval",
          "items": [
            {
              "type": "flex",
              "data-slot": "dt-node-header",
              "items": [
                { "type": "icon", "icon": "user-check", "data-slot": "dt-node-icon" },
                { "type": "text", "body": "${label}", "data-slot": "dt-node-title" }
              ]
            },
            {
              "type": "text",
              "body": "${examineMode === 1 ? '依次审批' : examineMode === 2 ? '会签' : examineMode === 3 ? '或签' : '审批'}",
              "data-slot": "dt-node-subtitle"
            }
          ]
        },
        "appearance": { "minWidth": 220, "minHeight": 80 },
        "inspector": {
          "body": {
            "type": "container",
            "className": "stack-sm",
            "body": [
              {
                "type": "select",
                "name": "setType",
                "label": "审批人类型",
                "options": [
                  { "label": "指定成员", "value": "1" },
                  { "label": "主管", "value": "2" },
                  { "label": "角色", "value": "3" }
                ]
              },
              {
                "type": "select",
                "name": "examineMode",
                "label": "审批模式",
                "options": [
                  { "label": "依次审批", "value": "1" },
                  { "label": "会签", "value": "2" },
                  { "label": "或签", "value": "3" }
                ]
              }
            ]
          }
        },
        "tree": { "allowChild": true, "allowBranches": false, "isTerminal": false }
      },
      {
        "id": "dt-cc",
        "label": "抄送人",
        "icon": "mail",
        "body": {
          "type": "flex",
          "direction": "column",
          "gap": 4,
          "className": "dt-node-root",
          "data-slot": "dt-node",
          "data-node-variant": "cc",
          "items": [
            {
              "type": "flex",
              "data-slot": "dt-node-header",
              "items": [
                { "type": "icon", "icon": "mail", "data-slot": "dt-node-icon" },
                { "type": "text", "body": "${label}", "data-slot": "dt-node-title" }
              ]
            },
            { "type": "text", "body": "抄送给相关人员", "data-slot": "dt-node-subtitle" }
          ]
        },
        "appearance": { "minWidth": 200, "minHeight": 80 },
        "tree": { "allowChild": true, "allowBranches": false, "isTerminal": false }
      },
      {
        "id": "dt-condition",
        "label": "条件分支",
        "icon": "git-branch",
        "body": {
          "type": "flex",
          "direction": "column",
          "gap": 4,
          "className": "dt-node-root",
          "data-slot": "dt-node",
          "data-node-variant": "condition",
          "items": [
            {
              "type": "flex",
              "data-slot": "dt-node-header",
              "items": [{ "type": "text", "body": "${label}", "data-slot": "dt-node-title" }]
            },
            { "type": "text", "body": "排他分支", "data-slot": "dt-node-description" }
          ]
        },
        "appearance": { "minWidth": 200, "minHeight": 80 },
        "inspector": {
          "body": {
            "type": "container",
            "className": "stack-sm",
            "body": [
              {
                "type": "select",
                "name": "mode",
                "label": "分支模式",
                "options": [
                  { "label": "排他", "value": "exclusive" },
                  { "label": "并行", "value": "parallel" }
                ]
              }
            ]
          }
        },
        "tree": {
          "allowChild": true,
          "allowBranches": true,
          "minBranches": 2,
          "maxBranches": 10,
          "isTerminal": false
        }
      },
      {
        "id": "dt-parallel",
        "label": "并行分支",
        "icon": "git-merge",
        "body": {
          "type": "flex",
          "direction": "column",
          "gap": 4,
          "className": "dt-node-root",
          "data-slot": "dt-node",
          "data-node-variant": "parallel",
          "items": [
            {
              "type": "flex",
              "data-slot": "dt-node-header",
              "items": [
                { "type": "icon", "icon": "git-merge", "data-slot": "dt-node-icon" },
                { "type": "text", "body": "${label}", "data-slot": "dt-node-title" }
              ]
            },
            { "type": "text", "body": "同时执行多个分支", "data-slot": "dt-node-subtitle" }
          ]
        },
        "appearance": { "minWidth": 200, "minHeight": 80 },
        "tree": {
          "allowChild": true,
          "allowBranches": true,
          "minBranches": 2,
          "maxBranches": 10,
          "isTerminal": false
        }
      },
      {
        "id": "dt-subprocess",
        "label": "子流程",
        "icon": "layers",
        "body": {
          "type": "flex",
          "direction": "column",
          "gap": 4,
          "className": "dt-node-root",
          "data-slot": "dt-node",
          "data-node-variant": "subprocess",
          "items": [
            {
              "type": "flex",
              "data-slot": "dt-node-header",
              "items": [
                { "type": "icon", "icon": "layers", "data-slot": "dt-node-icon" },
                { "type": "text", "body": "${label}", "data-slot": "dt-node-title" }
              ]
            },
            { "type": "text", "body": "${callProcess}", "data-slot": "dt-node-subtitle" }
          ]
        },
        "appearance": { "minWidth": 200, "minHeight": 80 },
        "inspector": {
          "body": {
            "type": "container",
            "className": "stack-sm",
            "body": [
              {
                "type": "input-text",
                "name": "callProcess",
                "label": "子流程标识"
              }
            ]
          }
        },
        "tree": { "allowChild": true, "allowBranches": false, "isTerminal": false }
      },
      {
        "id": "dt-end",
        "label": "结束",
        "icon": "square",
        "body": {
          "type": "flex",
          "direction": "column",
          "justifyContent": "center",
          "alignItems": "center",
          "className": "dt-node-root",
          "data-slot": "dt-node",
          "data-node-variant": "end",
          "items": [{ "type": "text", "body": "${label}", "data-slot": "dt-node-title" }]
        },
        "appearance": { "minWidth": 120, "minHeight": 40 },
        "tree": { "allowChild": false, "allowBranches": false, "isTerminal": true }
      }
    ],
    "edgeTypes": [
      {
        "id": "dt-chain",
        "label": "流程连线",
        "appearance": { "stroke": "#94a3b8", "strokeWidth": 2, "markerEnd": "arrow-closed" }
      },
      {
        "id": "dt-branch",
        "label": "分支连线",
        "appearance": {
          "stroke": "#3b82f6",
          "strokeWidth": 2,
          "strokeStyle": "dashed",
          "markerEnd": "arrow-closed"
        }
      },
      {
        "id": "dt-merge",
        "label": "汇合连线",
        "appearance": {
          "stroke": "#94a3b8",
          "strokeWidth": 1.5,
          "strokeStyle": "dotted",
          "markerEnd": "arrow-closed"
        }
      }
    ],
    "toolbar": {
      "items": [
        { "type": "back", "label": "返回", "action": "designer:navigate-back" },
        { "type": "title", "body": "钉钉审批流" },
        { "type": "badge", "level": "info", "text": "Tree Mode" },
        { "type": "divider" },
        { "type": "spacer" },
        { "type": "button", "action": "designer:export", "icon": "file-json", "label": "JSON" }
      ]
    },
    "features": {
      "undo": true,
      "redo": true,
      "history": true,
      "grid": true,
      "minimap": false,
      "fitView": true,
      "export": true,
      "shortcuts": true,
      "clipboard": false
    },
    "canvas": {
      "background": "dots",
      "gridSize": 24,
      "minZoom": 0.3,
      "maxZoom": 2
    }
  }
}
