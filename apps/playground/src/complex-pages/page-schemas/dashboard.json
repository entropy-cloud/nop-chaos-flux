{
  "type": "page",
  "testid": "dashboard-page",
  "body": [
    {
      "type": "data-source",
      "name": "summary",
      "action": "ajax",
      "args": { "url": "/r/Dashboard__summary", "method": "get" },
      "testid": "dash-summary-source"
    },
    {
      "type": "data-source",
      "name": "trend",
      "action": "ajax",
      "args": { "url": "/r/Dashboard__trend", "method": "get" }
    },
    {
      "type": "data-source",
      "name": "daily",
      "action": "ajax",
      "args": { "url": "/r/Dashboard__daily", "method": "get" }
    },
    {
      "type": "data-source",
      "name": "category",
      "action": "ajax",
      "args": { "url": "/r/Dashboard__category", "method": "get" }
    },
    {
      "type": "data-source",
      "name": "recentOrders",
      "action": "ajax",
      "args": { "url": "/r/Dashboard__recentOrders", "method": "get" }
    },
    {
      "type": "data-source",
      "name": "approvals",
      "action": "ajax",
      "args": { "url": "/r/Dashboard__approvals", "method": "get" }
    },
    {
      "type": "container",
      "className": "mb-3",
      "body": [
        { "type": "text", "text": "仪表盘", "className": "text-lg font-semibold" },
        {
          "type": "text",
          "text": "实时业务概览",
          "className": "text-xs text-muted-foreground mt-0.5"
        }
      ]
    },
    {
      "type": "flex",
      "direction": "row",
      "wrap": true,
      "gap": 12,
      "className": "mb-4",
      "body": [
        {
          "type": "container",
          "testid": "dash-stat-total",
          "className": "flex-1 rounded-xl bg-card ring-1 ring-foreground/10 shadow-sm overflow-hidden dash-card",
          "body": [
            { "type": "text", "text": "", "className": "block h-1 w-full bg-blue-500" },
            {
              "type": "container",
              "className": "p-4",
              "body": [
                {
                  "type": "flex",
                  "direction": "row",
                  "gap": 8,
                  "className": "items-center mb-3",
                  "body": [
                    {
                      "type": "container",
                      "className": "rounded-lg bg-muted p-1.5 dash-icon-bg",
                      "body": [
                        {
                          "type": "icon",
                          "icon": "shopping-cart",
                          "size": 14,
                          "color": "#2563eb",
                          "className": "dash-icon-el"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "订单总数",
                      "className": "text-xs text-muted-foreground font-medium"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "${summary?.totalOrders ?? 0}",
                  "className": "text-3xl font-bold leading-none"
                },
                {
                  "type": "text",
                  "text": "累计订单",
                  "className": "text-xs text-muted-foreground mt-2"
                }
              ]
            }
          ]
        },
        {
          "type": "container",
          "testid": "dash-stat-today",
          "className": "flex-1 rounded-xl bg-card ring-1 ring-foreground/10 shadow-sm overflow-hidden dash-card",
          "body": [
            { "type": "text", "text": "", "className": "block h-1 w-full bg-emerald-500" },
            {
              "type": "container",
              "className": "p-4",
              "body": [
                {
                  "type": "flex",
                  "direction": "row",
                  "gap": 8,
                  "className": "items-center mb-3",
                  "body": [
                    {
                      "type": "container",
                      "className": "rounded-lg bg-muted p-1.5 dash-icon-bg",
                      "body": [
                        {
                          "type": "icon",
                          "icon": "activity",
                          "size": 14,
                          "color": "#059669",
                          "className": "dash-icon-el"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "今日订单",
                      "className": "text-xs text-muted-foreground font-medium"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "${summary?.todayOrders ?? 0}",
                  "className": "text-3xl font-bold leading-none"
                },
                { "type": "text", "text": "笔", "className": "text-xs text-muted-foreground mt-2" }
              ]
            }
          ]
        },
        {
          "type": "container",
          "testid": "dash-stat-active",
          "className": "flex-1 rounded-xl bg-card ring-1 ring-foreground/10 shadow-sm overflow-hidden dash-card",
          "body": [
            { "type": "text", "text": "", "className": "block h-1 w-full bg-violet-500" },
            {
              "type": "container",
              "className": "p-4",
              "body": [
                {
                  "type": "flex",
                  "direction": "row",
                  "gap": 8,
                  "className": "items-center mb-3",
                  "body": [
                    {
                      "type": "container",
                      "className": "rounded-lg bg-muted p-1.5 dash-icon-bg",
                      "body": [
                        {
                          "type": "icon",
                          "icon": "zap",
                          "size": 14,
                          "color": "#7c3aed",
                          "className": "dash-icon-el"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "活跃订单",
                      "className": "text-xs text-muted-foreground font-medium"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "${summary?.active ?? 0}",
                  "className": "text-3xl font-bold leading-none"
                },
                {
                  "type": "text",
                  "text": "进行中",
                  "className": "text-xs text-muted-foreground mt-2"
                }
              ]
            }
          ]
        },
        {
          "type": "container",
          "testid": "dash-stat-pending",
          "className": "flex-1 rounded-xl bg-card ring-1 ring-foreground/10 shadow-sm overflow-hidden dash-card",
          "body": [
            { "type": "text", "text": "", "className": "block h-1 w-full bg-amber-500" },
            {
              "type": "container",
              "className": "p-4",
              "body": [
                {
                  "type": "flex",
                  "direction": "row",
                  "gap": 8,
                  "className": "items-center mb-3",
                  "body": [
                    {
                      "type": "container",
                      "className": "rounded-lg bg-muted p-1.5 dash-icon-bg",
                      "body": [
                        {
                          "type": "icon",
                          "icon": "clock",
                          "size": 14,
                          "color": "#d97706",
                          "className": "dash-icon-el"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "待付款",
                      "className": "text-xs text-muted-foreground font-medium"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "${summary?.pending ?? 0}",
                  "className": "text-3xl font-bold leading-none"
                },
                {
                  "type": "text",
                  "text": "待处理",
                  "className": "text-xs text-muted-foreground mt-2"
                }
              ]
            }
          ]
        },
        {
          "type": "container",
          "testid": "dash-stat-revenue",
          "className": "flex-1 rounded-xl bg-card ring-1 ring-foreground/10 shadow-sm overflow-hidden dash-card",
          "body": [
            { "type": "text", "text": "", "className": "block h-1 w-full bg-cyan-500" },
            {
              "type": "container",
              "className": "p-4",
              "body": [
                {
                  "type": "flex",
                  "direction": "row",
                  "gap": 8,
                  "className": "items-center mb-3",
                  "body": [
                    {
                      "type": "container",
                      "className": "rounded-lg bg-muted p-1.5 dash-icon-bg",
                      "body": [
                        {
                          "type": "icon",
                          "icon": "dollar-sign",
                          "size": 14,
                          "color": "#0891b2",
                          "className": "dash-icon-el"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "累计收入",
                      "className": "text-xs text-muted-foreground font-medium"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "${summary?.revenue ?? 0}",
                  "className": "text-3xl font-bold leading-none"
                },
                { "type": "text", "text": "元", "className": "text-xs text-muted-foreground mt-2" }
              ]
            }
          ]
        },
        {
          "type": "container",
          "testid": "dash-stat-growth",
          "className": "flex-1 rounded-xl bg-card ring-1 ring-foreground/10 shadow-sm overflow-hidden dash-card",
          "body": [
            { "type": "text", "text": "", "className": "block h-1 w-full bg-rose-500" },
            {
              "type": "container",
              "className": "p-4",
              "body": [
                {
                  "type": "flex",
                  "direction": "row",
                  "gap": 8,
                  "className": "items-center mb-3",
                  "body": [
                    {
                      "type": "container",
                      "className": "rounded-lg bg-muted p-1.5 dash-icon-bg",
                      "body": [
                        {
                          "type": "icon",
                          "icon": "trending-up",
                          "size": 14,
                          "color": "#e11d48",
                          "className": "dash-icon-el"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": "月增长率",
                      "className": "text-xs text-muted-foreground font-medium"
                    }
                  ]
                },
                {
                  "type": "text",
                  "text": "${summary?.monthGrowth ?? \"0%\"}",
                  "className": "text-3xl font-bold leading-none"
                },
                {
                  "type": "text",
                  "text": "较上月",
                  "className": "text-xs text-muted-foreground mt-2"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "flex",
      "direction": "row",
      "gap": 12,
      "className": "mb-4",
      "body": [
        {
          "type": "container",
          "className": "flex-1 border rounded-lg p-3 bg-background",
          "body": [
            { "type": "text", "text": "销售趋势", "className": "text-sm font-semibold mb-2" },
            {
              "type": "chart",
              "testid": "dash-trend-chart",
              "chartType": "area",
              "source": "${trend?.items}",
              "height": 240,
              "xAxis": { "dataKey": "date" },
              "series": [{ "name": "销售额", "dataRegionKey": "amount" }],
              "grid": true,
              "legend": true
            }
          ]
        },
        {
          "type": "container",
          "className": "flex-1 border rounded-lg p-3 bg-background",
          "body": [
            { "type": "text", "text": "每日订单", "className": "text-sm font-semibold mb-2" },
            {
              "type": "chart",
              "testid": "dash-daily-chart",
              "chartType": "bar",
              "source": "${daily?.items}",
              "height": 240,
              "xAxis": { "dataKey": "date" },
              "series": [
                { "name": "订单笔数", "dataRegionKey": "count" },
                { "name": "销售额", "dataRegionKey": "amount" }
              ],
              "grid": true,
              "legend": true
            }
          ]
        },
        {
          "type": "container",
          "className": "flex-1 border rounded-lg p-3 bg-background",
          "body": [
            { "type": "text", "text": "渠道占比", "className": "text-sm font-semibold mb-2" },
            {
              "type": "chart",
              "testid": "dash-category-chart",
              "chartType": "pie",
              "source": "${category?.items}",
              "height": 240,
              "xAxis": { "dataKey": "name" },
              "series": [{ "name": "订单数", "dataRegionKey": "value" }],
              "legend": true
            }
          ]
        }
      ]
    },
    {
      "type": "flex",
      "direction": "row",
      "gap": 12,
      "className": "mb-4",
      "body": [
        {
          "type": "container",
          "className": "flex-1 border rounded-lg p-3 bg-background",
          "body": [
            { "type": "text", "text": "最近订单", "className": "text-sm font-semibold mb-2" },
            {
              "type": "table",
              "testid": "dash-recent-table",
              "source": "${recentOrders?.items}",
              "rowKey": "id",
              "pagination": { "enabled": false },
              "empty": { "type": "text", "text": "暂无订单" },
              "columns": [
                { "name": "orderNo", "label": "订单号", "width": 180 },
                { "name": "customer", "label": "客户", "width": 180 },
                { "name": "amount", "label": "金额", "width": 100 },
                { "name": "status_label", "label": "状态", "width": 100 },
                { "name": "channel_label", "label": "渠道", "width": 90 },
                { "name": "createTime", "label": "创建时间", "width": 170 }
              ]
            }
          ]
        },
        {
          "type": "container",
          "className": "flex-1 border rounded-lg p-3 bg-background",
          "body": [
            { "type": "text", "text": "待审批任务", "className": "text-sm font-semibold mb-2" },
            {
              "type": "table",
              "testid": "dash-approvals-table",
              "source": "${approvals?.items}",
              "rowKey": "id",
              "pagination": { "enabled": false },
              "empty": { "type": "text", "text": "暂无待审批" },
              "columns": [
                { "name": "title", "label": "标题", "width": 200 },
                { "name": "applicant", "label": "申请人", "width": 80 },
                { "name": "status_label", "label": "状态", "width": 70 },
                { "name": "department", "label": "部门", "width": 80 },
                { "name": "amount", "label": "金额(元)", "width": 100 },
                { "name": "submitTime", "label": "提交时间", "width": 160 }
              ]
            }
          ]
        }
      ]
    }
  ]
}
