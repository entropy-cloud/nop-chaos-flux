{
  "type": "form",
  "mode": "horizontal",
  "labelAlign": "right",
  "labelWidth": "sm",
  "id": "profile-form",
  "data": {
    "fullName": "Alice",
    "email": "alice@example.com"
  },
  "body": [
    {
      "type": "fieldset",
      "title": "基本信息",
      "collapsible": true,
      "body": [
        {
          "type": "flex",
          "direction": "row",
          "gap": "md",
          "items": [
            {
              "type": "input-text",
              "name": "fullName",
              "label": "姓名",
              "required": true,
              "hint": "请输入真实姓名"
            },
            {
              "type": "input-email",
              "name": "email",
              "label": "邮箱",
              "required": true,
              "description": "用于接收系统通知",
              "labelRemark": {
                "content": "请使用公司邮箱"
              }
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "button",
      "label": "提交",
      "variant": "default",
      "onClick": {
        "action": "component:submit",
        "componentId": "profile-form"
      }
    }
  ]
}
