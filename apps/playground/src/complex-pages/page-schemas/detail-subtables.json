{
  "type": "page",
  "testid": "detail-subtables-page",
  "body": [
    {
      "type": "data-source",
      "name": "orderPicker",
      "action": "ajax",
      "args": { "url": "/r/Order__pickerOptions", "method": "get" },
      "testid": "ds-order-options-source"
    },
    {
      "type": "form",
      "valuesPath": "detailFilter",
      "data": { "orderId": "o1" },
      "testid": "ds-order-picker-form",
      "bodyClassName": "mb-3",
      "body": [
        {
          "type": "select",
          "name": "orderId",
          "label": "选择订单",
          "testid": "ds-order-picker",
          "options": "${orderPicker?.items}"
        }
      ]
    },
    {
      "type": "data-source",
      "name": "orderDetail",
      "dependsOn": ["detailFilter"],
      "sendOn": "detailFilter?.orderId",
      "action": "ajax",
      "args": {
        "url": "/r/Order__get",
        "method": "get",
        "data": { "id": "${detailFilter?.orderId}" }
      },
      "testid": "ds-detail-source"
    },
    {
      "type": "data-source",
      "name": "orderItems",
      "dependsOn": ["detailFilter"],
      "sendOn": "detailFilter?.orderId",
      "action": "ajax",
      "args": {
        "url": "/r/OrderItem__find",
        "method": "get",
        "data": { "orderId": "${detailFilter?.orderId}" }
      }
    },
    {
      "type": "data-source",
      "name": "orderLogs",
      "dependsOn": ["detailFilter"],
      "sendOn": "detailFilter?.orderId",
      "action": "ajax",
      "args": {
        "url": "/r/OrderLog__find",
        "method": "get",
        "data": { "orderId": "${detailFilter?.orderId}" }
      }
    },
    {
      "type": "data-source",
      "name": "orderAddresses",
      "dependsOn": ["detailFilter"],
      "sendOn": "detailFilter?.orderId",
      "action": "ajax",
      "args": {
        "url": "/r/Address__find",
        "method": "get",
        "data": { "orderId": "${detailFilter?.orderId}" }
      }
    },
    {
      "type": "data-source",
      "name": "orderPayments",
      "dependsOn": ["detailFilter"],
      "sendOn": "detailFilter?.orderId",
      "action": "ajax",
      "args": {
        "url": "/r/Payment__find",
        "method": "get",
        "data": { "orderId": "${detailFilter?.orderId}" }
      }
    },
    {
      "type": "data-source",
      "name": "orderShipments",
      "dependsOn": ["detailFilter"],
      "sendOn": "detailFilter?.orderId",
      "action": "ajax",
      "args": {
        "url": "/r/Shipment__find",
        "method": "get",
        "data": { "orderId": "${detailFilter?.orderId}" }
      }
    },
    {
      "type": "container",
      "className": "border rounded-lg p-4 mb-3 bg-background",
      "body": [
        { "type": "text", "text": "订单详情", "className": "text-base font-semibold mb-2" },
        {
          "type": "flex",
          "direction": "row",
          "gap": 16,
          "body": [
            {
              "type": "text",
              "text": "单号：${orderDetail?.orderNo ?? \"-\"}",
              "className": "text-sm"
            },
            {
              "type": "text",
              "text": "客户：${orderDetail?.customer ?? \"-\"}",
              "className": "text-sm"
            },
            {
              "type": "text",
              "text": "金额：${orderDetail?.amount ?? \"-\"}",
              "className": "text-sm"
            },
            {
              "type": "text",
              "text": "状态：${orderDetail?.status_label ?? \"-\"}",
              "className": "text-sm"
            },
            {
              "type": "text",
              "text": "创建：${orderDetail?.createTime ?? \"-\"}",
              "className": "text-sm"
            }
          ]
        }
      ]
    },
    {
      "type": "tabs",
      "testid": "ds-sub-tabs",
      "className": "mb-3",
      "items": [
        {
          "key": "items",
          "title": "订单明细",
          "body": [
            {
              "type": "table",
              "testid": "ds-items-table",
              "source": "${orderItems?.items}",
              "rowKey": "id",
              "empty": { "type": "text", "text": "暂无明细" },
              "columns": [
                { "name": "sku", "label": "SKU", "width": 140 },
                { "name": "name", "label": "商品", "width": 200 },
                { "name": "qty", "label": "数量", "width": 80 },
                { "name": "price", "label": "单价", "width": 100 }
              ]
            }
          ]
        },
        {
          "key": "logs",
          "title": "操作日志",
          "body": [
            {
              "type": "table",
              "testid": "ds-logs-table",
              "source": "${orderLogs?.items}",
              "rowKey": "id",
              "empty": { "type": "text", "text": "暂无日志" },
              "columns": [
                { "name": "time", "label": "时间", "width": 180 },
                { "name": "action", "label": "操作", "width": 140 },
                { "name": "operator", "label": "操作人", "width": 120 }
              ]
            }
          ]
        },
        {
          "key": "addresses",
          "title": "收货地址",
          "body": [
            {
              "type": "table",
              "testid": "ds-addresses-table",
              "source": "${orderAddresses?.items}",
              "rowKey": "id",
              "empty": { "type": "text", "text": "暂无收货地址" },
              "columns": [
                { "name": "recipient", "label": "收件人", "width": 120 },
                { "name": "phone", "label": "电话", "width": 150 },
                { "name": "address", "label": "地址", "width": 320 }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "container",
      "className": "border rounded-lg p-3 mb-3 bg-background",
      "body": [
        { "type": "text", "text": "付款记录", "className": "text-sm font-semibold mb-2" },
        {
          "type": "table",
          "testid": "ds-payments-table",
          "source": "${orderPayments?.items}",
          "rowKey": "id",
          "empty": { "type": "text", "text": "暂无付款记录" },
          "columns": [
            { "name": "time", "label": "时间", "width": 180 },
            { "name": "method_label", "label": "方式", "width": 100 },
            { "name": "amount", "label": "金额", "width": 100 },
            { "name": "status_label", "label": "状态", "width": 100 }
          ]
        }
      ]
    },
    {
      "type": "container",
      "className": "border rounded-lg p-3 bg-background",
      "body": [
        { "type": "text", "text": "物流轨迹", "className": "text-sm font-semibold mb-2" },
        {
          "type": "table",
          "testid": "ds-shipments-table",
          "source": "${orderShipments?.items}",
          "rowKey": "id",
          "empty": { "type": "text", "text": "暂无物流信息" },
          "columns": [
            { "name": "time", "label": "时间", "width": 180 },
            { "name": "station", "label": "站点", "width": 160 },
            { "name": "description", "label": "描述", "width": 200 }
          ]
        }
      ]
    }
  ]
}
