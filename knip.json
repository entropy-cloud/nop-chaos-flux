{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": [
    "docs/**",
    ".opencode/**",
    ".stryker-tmp/**",
    ".venv/**",
    "dist/**",
    "coverage/**",
    "test-results/**"
  ],
  "workspaces": {
    "apps/playground": {
      "entry": [
        "package.json",
        "src/**/*.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "@nop-chaos/theme-tokens"
      ]
    },
    "packages/*": {
      "entry": [
        "package.json",
        "src/index.{ts,tsx}",
        "src/**/*.{test,spec}.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    }
  }
}
