                  { "label": "技术部", "value": "tech" },
                  { "label": "产品部", "value": "product" }
                ]
              },
              {
                "type": "input-date",
                "name": "joinDate",
                "label": "入职日期"
              },
              {
                "type": "checkbox",
                "name": "agree",
                "label": "同意用户协议",
                "labelRemark": {
                  "content": "点击查看用户协议详情"
                }
              }
            ]
          }
        ]
      }
    ],
    "actions": [
      {
        "type": "button",
        "label": "提交",
        "variant": "default",
        "onClick": { "action": "component:submit" }
      },
      {
        "type": "button",
        "label": "重置",
        "onClick": { "action": "component:reset" }
      }
    ]
  }
}
