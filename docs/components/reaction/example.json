{
  "type": "reaction",
  "watch": "currentUser.role",
  "when": "${currentUser.role === 'admin'}",
  "immediate": true,
  "once": true,
  "actions": {
    "action": "openDialog",
    "args": {
      "title": "管理员提示",
      "body": {
        "type": "text",
        "text": "当前用户具备管理员权限。"
      }
    }
  }
}
