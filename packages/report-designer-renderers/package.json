{
  "name": "@nop-chaos/report-designer-renderers",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./report-field-panel.css": {
      "default": "./dist/report-field-panel.css"
    }
  },
  "dependencies": {
    "@nop-chaos/spreadsheet-core": "workspace:*",
    "@nop-chaos/flux-formula": "workspace:*",
    "@nop-chaos/spreadsheet-renderers": "workspace:*",
    "@nop-chaos/report-designer-core": "workspace:*",
    "@nop-chaos/flux-react": "workspace:*",
    "@nop-chaos/flux-runtime": "workspace:*",
    "@nop-chaos/flux-core": "workspace:*",
    "@nop-chaos/flux-i18n": "workspace:*",
    "@nop-chaos/ui": "workspace:*",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"fs.cpSync('src/report-field-panel.css','dist/report-field-panel.css')\"",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location node_modules/.cache/eslint"
  }
}
