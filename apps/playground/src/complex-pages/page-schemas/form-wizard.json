{
  "type": "page",
  "testid": "form-wizard-page",
  "body": [
    {
      "type": "wizard",
      "testid": "demo-wizard",
      "statusPath": "wizardStatus",
      "mountOnEnter": true,
      "steps": [
        {
          "key": "basic",
          "title": "基本信息",
          "description": "填写账号基础信息",
          "formId": "wizard-step1-form",
          "body": [
            {
              "type": "form",
              "id": "wizard-step1-form",
              "testid": "wizard-step1-form",
              "valuesPath": "wizardData.step1",
              "body": [
                {
                  "type": "input-text",
                  "name": "name",
                  "label": "姓名",
                  "required": true,
                  "placeholder": "请输入姓名"
                },
                {
                  "type": "input-text",
                  "name": "email",
                  "label": "邮箱",
                  "required": true,
                  "placeholder": "请输入邮箱"
                }
              ]
            }
          ]
        },
        {
          "key": "detail",
          "title": "详细信息",
          "description": "补充角色与部门",
          "formId": "wizard-step2-form",
          "body": [
            {
              "type": "form",
              "id": "wizard-step2-form",
              "testid": "wizard-step2-form",
              "valuesPath": "wizardData.step2",
              "body": [
                {
                  "type": "select",
                  "name": "role",
                  "label": "角色",
                  "required": true,
                  "dict": "role"
                },
                {
                  "type": "picker",
                  "name": "deptId",
                  "label": "部门",
                  "valueKey": "id",
                  "labelKey": "name",
                  "searchable": true,
                  "pickerDialog": { "title": "选择部门" },
                  "loadAction": {
                    "action": "ajax",
                    "args": {
                      "url": "/r/Department__findPage",
                      "method": "get",
                      "selection": "id,name"
                    }
                  },
                  "columns": [
                    { "name": "id", "label": "编码", "width": 120 },
                    { "name": "name", "label": "部门名称", "width": 200 }
                  ]
                },
                {
                  "type": "input-number",
                  "name": "budget",
                  "label": "预算额度(万)",
                  "min": 0
                },
                {
                  "type": "switch",
                  "name": "notify",
                  "label": "接收通知"
                }
              ]
            }
          ]
        },
        {
          "key": "confirm",
          "title": "确认提交",
          "description": "核对信息并提交",
          "body": [
            {
              "type": "fieldset",
              "title": "信息确认",
              "body": [
                {
                  "type": "text",
                  "text": "姓名：${wizardData.step1.name || \"-\"}",
                  "className": "text-sm"
                },
                {
                  "type": "text",
                  "text": "邮箱：${wizardData.step1.email || \"-\"}",
                  "className": "text-sm"
                },
                {
                  "type": "text",
                  "text": "角色：${wizardData.step2.role || \"-\"}",
                  "className": "text-sm"
                },
                {
                  "type": "text",
                  "text": "预算：${wizardData.step2.budget ?? 0} 万",
                  "className": "text-sm"
                },
                {
                  "type": "text",
                  "text": "通知：${wizardData.step2.notify ? \"开启\" : \"关闭\"}",
                  "className": "text-sm"
                }
              ]
            },
            {
              "type": "alert",
              "level": "info",
              "body": "点击\"完成\"将提交表单。",
              "className": "mt-2"
            }
          ]
        }
      ],
      "onComplete": {
        "action": "ajax",
        "args": {
          "url": "/r/User__save",
          "method": "post",
          "data": {
            "name": "${wizardData.step1.name}",
            "email": "${wizardData.step1.email}",
            "role": "${wizardData.step2.role}",
            "budget": "${wizardData.step2.budget ?? 0}",
            "notify": "${wizardData.step2.notify ?? false}"
          }
        },
        "messages": { "success": "提交成功" },
        "then": [{ "action": "setValue", "args": { "path": "wizardSubmitted", "value": true } }]
      }
    },
    {
      "type": "text",
      "testid": "wizard-submit-report",
      "text": "提交状态：${wizardSubmitted ? \"已完成 ✓\" : \"未提交\"}",
      "className": "text-sm mt-3"
    }
  ]
}
