{
  "name": "nop-chaos-flux-workspace",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @nop-chaos/flux-playground dev",
    "postinstall": "node scripts/patch-lucide-react.mjs",
    "check": "pnpm check:react19 && pnpm check:src-artifacts && pnpm check:oversized-code-files && pnpm check:i18n-keys",
    "audit:deps": "depcruise --config .dependency-cruiser.cjs apps packages scripts",
    "audit:knip": "knip --config knip.json",
    "audit:mutants": "stryker run stryker.runtime.conf.mjs",
    "audit:semgrep": "semgrep --config .semgrep.yml .",
    "build": "pnpm -r --workspace-concurrency=4 build",
    "typecheck": "pnpm -r --workspace-concurrency=4 typecheck",
    "test": "pnpm -r --workspace-concurrency=4 test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "check:react19": "node scripts/check-react19-legacy-apis.mjs",
    "check:oversized-code-files": "node scripts/check-oversized-code-files.mjs",
    "check:src-artifacts": "node scripts/verify-no-src-artifacts.mjs",
    "check:i18n-keys": "node scripts/check-i18n-keys.mjs",
    "lint": "node scripts/clean-src-artifacts.mjs && node scripts/verify-no-src-artifacts.mjs && node scripts/check-react19-legacy-apis.mjs && node scripts/check-i18n-keys.mjs && pnpm -r --workspace-concurrency=4 lint",
    "clean": "pnpm -r exec npx rimraf node_modules dist && npx rimraf node_modules",
    "clean:src-artifacts": "node scripts/clean-src-artifacts.mjs"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "i18next": "^26.0.5",
    "jsdom": "^29.0.1",
    "dependency-cruiser": "^17.3.10",
    "knip": "^6.9.0",
    "react-i18next": "^17.0.4",
    "rimraf": "^6.1.3",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
