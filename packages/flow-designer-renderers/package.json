{
  "name": "@nop-chaos/flow-designer-renderers",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./unstable": {
      "types": "./dist/unstable.d.ts",
      "default": "./dist/unstable.js"
    },
    "./designer-theme.css": {
      "default": "./dist/designer-theme.css"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/copy-build-assets.mjs src/designer-theme.css dist/designer-theme.css",
    "typecheck": "tsc -p tsconfig.json",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location node_modules/.cache/eslint"
  },
  "dependencies": {
    "@nop-chaos/flow-designer-core": "workspace:*",
    "@nop-chaos/flux-core": "workspace:*",
    "@nop-chaos/flux-i18n": "workspace:*",
    "@nop-chaos/flux-react": "workspace:*",
    "@nop-chaos/ui": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "use-sync-external-store": "^1.6.0"
  },
  "peerDependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@nop-chaos/flux-formula": "workspace:*",
    "@nop-chaos/flux-runtime": "workspace:*",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0"
  },
  "description": "React renderers for the flow designer visual editor"
}
