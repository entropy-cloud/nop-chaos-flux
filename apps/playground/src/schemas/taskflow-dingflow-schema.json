{
  "type": "designer-page",
  "xui:imports": [{ "from": "taskflow-designer", "as": "taskflow" }],
  "treeDocument": {
    "id": "tf-dingflow-demo",
    "kind": "nop-taskflow-dingflow",
    "name": "TaskFlow DingFlow Demo",
    "version": "1.0",
    "meta": { "syntheticRootId": "__synthetic_root__" },
    "root": {
      "id": "__synthetic_root__",
      "type": "tf-entry",
      "data": {},
      "child": {
        "id": "seq-1",
        "type": "tf-sequential",
        "data": {
          "step": {
            "id": "seq-1",
            "type": "sequential",
            "common": { "name": "initSequence" },
            "props": { "type": "sequential" }
          }
        },
        "child": {
          "id": "script-1",
          "type": "tf-script",
          "data": {
            "step": {
              "id": "script-1",
              "type": "script",
              "common": { "name": "loadData" },
              "props": { "type": "script", "lang": "js" }
            }
          },
          "child": {
            "id": "if-1",
            "type": "tf-if",
            "data": {
              "step": {
                "id": "if-1",
                "type": "if",
                "common": { "name": "checkCondition" },
                "props": { "type": "if", "condition": "true" }
              }
            },
            "branches": [
              {
                "id": "then-1",
                "data": { "branchType": "then", "label": "Valid" },
                "child": {
                  "id": "invoke-1",
                  "type": "tf-invoke",
                  "data": {
                    "step": {
                      "id": "invoke-1",
                      "type": "invoke",
                      "common": { "name": "processValid" },
                      "props": { "type": "invoke", "bean": "processor", "method": "handle" }
                    }
                  }
                }
              },
              {
                "id": "else-1",
                "data": { "branchType": "else", "label": "Invalid" },
                "child": {
                  "id": "script-2",
                  "type": "tf-script",
                  "data": {
                    "step": {
                      "id": "script-2",
                      "type": "script",
                      "common": { "name": "handleInvalid" },
                      "props": { "type": "script", "lang": "js" }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  },
  "config": {
    "version": "1.0",
    "kind": "nop-taskflow-dingflow",
    "documentMode": "tree",
    "treeConfig": {
      "layout": { "direction": "TB", "nodeSpacing": 40, "layerSpacing": 80 },
      "showGatewayNodes": true,
      "showMergeNodes": false,
      "autoLayout": true,
      "chainEdgeType": "tf-chain",
      "branchEdgeType": "tf-branch-edge",
      "mergeEdgeType": "tf-merge-edge"
    },
    "nodeTypes": [
      {
        "id": "tf-entry",
        "label": "Entry",
        "icon": "log-in",
        "description": "Synthetic root entry node",
        "constraints": { "maxInstances": 1 },
        "appearance": { "minWidth": 80, "minHeight": 32, "borderRadius": 16 },
        "tree": { "allowChild": true, "isTerminal": false },
        "body": {
          "type": "flex",
          "className": "items-center gap-1 px-2 py-1",
          "body": [
            { "type": "icon", "icon": "log-in", "className": "text-green-500 w-3 h-3" },
            { "type": "text", "text": "Entry" }
          ]
        }
      },
      {
        "id": "tf-sequential",
        "label": "Sequential",
        "icon": "list-ordered",
        "description": "Sequential step container",
        "appearance": { "minWidth": 130, "minHeight": 44 },
        "defaults": { "step": { "common": { "name": "seq" }, "props": { "type": "sequential" } } },
        "tree": { "allowChild": true, "isTerminal": false },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "list-ordered", "className": "text-teal-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "inspector": {
          "body": {
            "type": "form",
            "body": [{ "type": "input-text", "name": "step.common.name", "label": "Name" }]
          }
        }
      },
      {
        "id": "tf-parallel",
        "label": "Parallel",
        "icon": "columns",
        "description": "Parallel execution",
        "appearance": { "minWidth": 130, "minHeight": 44 },
        "defaults": {
          "step": { "common": { "name": "parallel" }, "props": { "type": "parallel" } }
        },
        "tree": {
          "allowChild": true,
          "allowBranches": true,
          "minBranches": 2,
          "maxBranches": 10,
          "isTerminal": false
        },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "columns", "className": "text-cyan-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              {
                "type": "select",
                "name": "step.props.joinType",
                "label": "Join Type",
                "options": {
                  "values": [
                    { "label": "Join All", "value": "joinAll" },
                    { "label": "Cancel On Error", "value": "cancelOnError" }
                  ]
                }
              }
            ]
          }
        }
      },
      {
        "id": "tf-script",
        "label": "Script",
        "icon": "code",
        "description": "Script step",
        "appearance": { "minWidth": 130, "minHeight": 44 },
        "defaults": {
          "step": { "common": { "name": "script" }, "props": { "type": "script", "lang": "js" } }
        },
        "tree": { "allowChild": true, "isTerminal": false },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "code", "className": "text-blue-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              {
                "type": "select",
                "name": "step.props.lang",
                "label": "Language",
                "options": {
                  "values": [
                    { "label": "JavaScript", "value": "js" },
                    { "label": "XPL", "value": "xpl" }
                  ]
                }
              }
            ]
          }
        }
      },
      {
        "id": "tf-invoke",
        "label": "Invoke",
        "icon": "zap",
        "description": "Invoke bean method",
        "appearance": { "minWidth": 130, "minHeight": 44 },
        "defaults": {
          "step": {
            "common": { "name": "invoke" },
            "props": { "type": "invoke", "bean": "", "method": "" }
          }
        },
        "tree": { "allowChild": true, "isTerminal": false },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "zap", "className": "text-yellow-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.props.bean", "label": "Bean" },
              { "type": "input-text", "name": "step.props.method", "label": "Method" }
            ]
          }
        }
      },
      {
        "id": "tf-if",
        "label": "If Condition",
        "icon": "git-branch",
        "description": "Conditional with then/else branches",
        "appearance": { "minWidth": 140, "minHeight": 44 },
        "defaults": { "step": { "common": { "name": "condition" }, "props": { "type": "if" } } },
        "tree": {
          "allowChild": true,
          "allowBranches": true,
          "minBranches": 2,
          "maxBranches": 2,
          "isTerminal": false
        },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "git-branch", "className": "text-purple-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.props.condition", "label": "Condition" }
            ]
          }
        }
      },
      {
        "id": "tf-choose",
        "label": "Choose",
        "icon": "list",
        "description": "Multi-branch choose",
        "appearance": { "minWidth": 140, "minHeight": 44 },
        "defaults": { "step": { "common": { "name": "choose" }, "props": { "type": "choose" } } },
        "tree": {
          "allowChild": true,
          "allowBranches": true,
          "minBranches": 1,
          "maxBranches": 10,
          "isTerminal": false
        },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "list", "className": "text-orange-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.props.decider", "label": "Decider" }
            ]
          }
        }
      },
      {
        "id": "tf-delay",
        "label": "Delay",
        "icon": "clock",
        "description": "Delay step",
        "appearance": { "minWidth": 130, "minHeight": 44 },
        "defaults": {
          "step": {
            "common": { "name": "delay" },
            "props": { "type": "delay", "delayMillisExpr": "1000" }
          }
        },
        "tree": { "allowChild": true, "isTerminal": false },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "clock", "className": "text-gray-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.props.delayMillisExpr", "label": "Delay (ms)" }
            ]
          }
        }
      },
      {
        "id": "tf-end",
        "label": "End",
        "icon": "stop-circle",
        "description": "Terminal node",
        "constraints": { "maxInstances": 1 },
        "appearance": { "minWidth": 80, "minHeight": 32, "borderRadius": 16 },
        "tree": { "allowChild": false, "isTerminal": true },
        "body": {
          "type": "flex",
          "className": "items-center gap-1 px-2 py-1",
          "body": [
            { "type": "icon", "icon": "stop-circle", "className": "text-red-500 w-3 h-3" },
            { "type": "text", "text": "End" }
          ]
        }
      }
    ],
    "edgeTypes": [
      {
        "id": "tf-chain",
        "label": "Chain",
        "appearance": { "stroke": "#6366f1", "strokeWidth": 2, "markerEnd": "arrow" }
      },
      {
        "id": "tf-branch-edge",
        "label": "Branch",
        "appearance": { "stroke": "#22c55e", "strokeWidth": 2, "markerEnd": "arrow" }
      },
      {
        "id": "tf-merge-edge",
        "label": "Merge",
        "appearance": { "stroke": "#a855f7", "strokeWidth": 2, "markerEnd": "arrow" }
      }
    ],
    "toolbar": {
      "items": [
        { "type": "title", "body": "TaskFlow (Tree)" },
        { "type": "text", "text": "Container: ${doc.name}" },
        { "type": "spacer" },
        {
          "type": "button",
          "action": "taskflow:exit-container",
          "label": "Back",
          "icon": "arrow-left"
        },
        {
          "type": "button",
          "action": "taskflow:export-json",
          "label": "Export",
          "icon": "download"
        },
        { "type": "button", "action": "taskflow:import-json", "label": "Import", "icon": "upload" },
        { "type": "button", "action": "taskflow:save", "label": "Save", "icon": "save" },
        { "type": "button", "action": "designer:undo", "label": "Undo", "icon": "undo" },
        { "type": "button", "action": "designer:redo", "label": "Redo", "icon": "redo" }
      ]
    },
    "features": { "undo": true, "redo": true, "grid": true, "minimap": true },
    "rules": { "defaultEdgeType": "tf-chain" },
    "canvas": {
      "background": "dots",
      "gridSize": 20,
      "snapToGrid": true,
      "minZoom": 0.25,
      "maxZoom": 4
    }
  }
}
