{
  "type": "designer-page",
  "xui:imports": [{ "from": "taskflow-designer", "as": "taskflow" }],
  "document": {
    "id": "tf-workflow-demo",
    "kind": "nop-taskflow-workflow",
    "name": "TaskFlow Workflow Demo",
    "version": "1.0",
    "viewport": { "x": 0, "y": 0, "zoom": 1 },
    "nodes": [
      {
        "id": "start-1",
        "type": "tf-start",
        "position": { "x": 50, "y": 200 },
        "data": {
          "step": {
            "id": "start-1",
            "type": "script",
            "common": { "name": "start" },
            "props": { "type": "script", "lang": "js", "source": "// init" }
          }
        }
      },
      {
        "id": "script-1",
        "type": "tf-script",
        "position": { "x": 250, "y": 200 },
        "data": {
          "step": {
            "id": "script-1",
            "type": "script",
            "common": { "name": "validateInput" },
            "props": { "type": "script", "lang": "js", "source": "// validate" }
          }
        }
      },
      {
        "id": "invoke-1",
        "type": "tf-invoke",
        "position": { "x": 450, "y": 200 },
        "data": {
          "step": {
            "id": "invoke-1",
            "type": "invoke",
            "common": { "name": "processOrder" },
            "props": { "type": "invoke", "bean": "orderService", "method": "process" }
          }
        }
      },
      {
        "id": "if-1",
        "type": "tf-if",
        "position": { "x": 650, "y": 200 },
        "data": {
          "step": {
            "id": "if-1",
            "type": "if",
            "common": { "name": "checkStatus" },
            "props": { "type": "if", "condition": "${status == 'ok'}" }
          }
        }
      },
      {
        "id": "delay-1",
        "type": "tf-delay",
        "position": { "x": 650, "y": 400 },
        "data": {
          "step": {
            "id": "delay-1",
            "type": "delay",
            "common": { "name": "waitBeforeRetry" },
            "props": { "type": "delay", "delayMillisExpr": "5000" }
          }
        }
      },
      {
        "id": "end-1",
        "type": "tf-end",
        "position": { "x": 850, "y": 200 },
        "data": {
          "step": {
            "id": "end-1",
            "type": "script",
            "common": { "name": "complete" },
            "props": { "type": "script", "lang": "js", "source": "// done" }
          }
        }
      },
      {
        "id": "graph-1",
        "type": "tf-graph",
        "position": { "x": 250, "y": 400 },
        "data": {
          "step": {
            "id": "graph-1",
            "type": "graph",
            "common": { "name": "subGraph" },
            "props": { "type": "graph" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "type": "tf-next",
        "source": "start-1",
        "target": "script-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e2",
        "type": "tf-next",
        "source": "script-1",
        "target": "invoke-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e3",
        "type": "tf-next",
        "source": "invoke-1",
        "target": "if-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e4",
        "type": "tf-error",
        "source": "invoke-1",
        "target": "delay-1",
        "sourcePort": "error",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-error", "label": "error" }
      },
      {
        "id": "e5",
        "type": "tf-next",
        "source": "if-1",
        "target": "end-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e6",
        "type": "tf-wait",
        "source": "script-1",
        "target": "graph-1",
        "sourcePort": "wait",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-wait", "label": "wait" }
      },
      {
        "id": "e7",
        "type": "tf-wait-error",
        "source": "invoke-1",
        "target": "graph-1",
        "sourcePort": "wait-error",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-wait-error", "label": "wait-error" }
      },
      {
        "id": "e8",
        "type": "tf-next",
        "source": "delay-1",
        "target": "invoke-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "retry" }
      }
    ]
  },
  "config": {
    "version": "1.0",
    "kind": "nop-taskflow-workflow",
    "documentMode": "graph",
    "classAliases": {
      "node-card": "nop-glass-card flex flex-col px-3 py-3 rounded-xl shadow-lg min-w-[192px] transition-all duration-150",
      "node-card--tf-start": "",
      "node-card--tf-end": "",
      "node-card--tf-script": "",
      "node-card--tf-invoke": "",
      "node-card--tf-if": "",
      "node-card--tf-choose": "",
      "node-card--tf-delay": "",
      "node-card--tf-sequential": "",
      "node-card--tf-graph": "",
      "node-card--tf-parallel": "",
      "node-info": "flex-1 min-w-0 flex flex-col gap-1",
      "node-header": "flex items-start gap-3",
      "node-icon": "w-10 h-10 rounded-xl flex items-center justify-center text-white shadow-sm shrink-0",
      "node-icon--tf-start": "nop-gradient-start",
      "node-icon--tf-end": "nop-gradient-end",
      "node-icon--tf-script": "nop-gradient-task",
      "node-icon--tf-invoke": "nop-gradient-parallel",
      "node-icon--tf-if": "nop-gradient-condition",
      "node-icon--tf-choose": "nop-gradient-condition",
      "node-icon--tf-delay": "nop-gradient-loop",
      "node-icon--tf-sequential": "nop-gradient-task",
      "node-icon--tf-graph": "nop-gradient-loop",
      "node-icon--tf-parallel": "nop-gradient-parallel",
      "node-title": "block text-sm leading-none font-semibold text-foreground whitespace-nowrap overflow-hidden text-ellipsis",
      "node-subtitle": "block text-sm leading-none text-muted-foreground line-clamp-2",
      "node-footer": "flex items-center justify-between gap-2 mt-3 text-sm text-muted-foreground",
      "node-badge": "text-sm px-2 py-1 rounded-full font-medium",
      "node-badge--tf-start": "text-emerald-700 bg-emerald-100",
      "node-badge--tf-end": "text-rose-800 bg-rose-100",
      "node-badge--tf-script": "text-sky-700 bg-sky-100",
      "node-badge--tf-invoke": "text-violet-800 bg-violet-100",
      "node-badge--tf-if": "text-amber-800 bg-amber-100",
      "node-badge--tf-choose": "text-amber-800 bg-amber-100",
      "node-badge--tf-delay": "text-pink-900 bg-fuchsia-100",
      "node-badge--tf-sequential": "text-sky-700 bg-sky-100",
      "node-badge--tf-graph": "text-pink-900 bg-fuchsia-100",
      "node-badge--tf-parallel": "text-violet-800 bg-violet-100"
    },
    "nodeTypes": [
      {
        "id": "tf-start",
        "label": "Start",
        "icon": "play-circle",
        "description": "Workflow start node",
        "constraints": { "maxInstances": 1, "allowIncoming": false },
        "defaults": { "step": { "common": { "name": "start" } } },
        "appearance": { "minWidth": 192, "minHeight": 112 },
        "body": {
          "type": "flex",
          "direction": "column",
          "className": "node-card node-card--tf-start",
          "items": [
            {
              "type": "flex",
              "className": "node-header",
              "items": [
                {
                  "type": "container",
                  "className": "node-icon node-icon--tf-start",
                  "body": [{ "type": "icon", "icon": "play-circle" }]
                },
                {
                  "type": "container",
                  "className": "node-info",
                  "bodyClassName": "flex flex-col gap-0",
                  "body": [
                    {
                      "type": "text",
                      "text": "${step.common.displayName || step.common.name}",
                      "className": "node-title"
                    },
                    {
                      "type": "text",
                      "text": "Process entry point",
                      "className": "node-subtitle"
                    }
                  ]
                }
              ]
            },
            {
              "type": "flex",
              "className": "node-footer",
              "items": [
                {
                  "type": "text",
                  "body": "Start",
                  "className": "node-badge node-badge--tf-start"
                },
                {
                  "type": "text",
                  "text": "${step.props.lang || 'js'}",
                  "className": "node-subtitle"
                }
              ]
            }
          ]
        },
        "ports": [
          {
            "id": "next",
            "direction": "output",
            "position": "right",
            "label": "next",
            "maxConnections": 1
          },
          {
            "id": "error",
            "direction": "output",
            "position": "bottom",
            "label": "error",
            "maxConnections": 1
          },
          {
            "id": "wait",
            "direction": "output",
            "position": "top",
            "label": "wait",
            "maxConnections": "unlimited"
          },
          {
            "id": "wait-error",
            "direction": "output",
            "position": "left",
            "label": "wait-error",
            "maxConnections": "unlimited"
          }
        ],
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.common.displayName", "label": "Display Name" },
              { "type": "input-text", "name": "step.props.source", "label": "Source" }
            ]
          }
        }
      },
      {
        "id": "tf-end",
        "label": "End",
        "icon": "stop-circle",
        "description": "Workflow end node",
        "constraints": { "maxInstances": 1, "allowOutgoing": false },
        "defaults": {},
        "appearance": { "minWidth": 192, "minHeight": 112 },
        "body": {
          "type": "flex",
          "direction": "column",
          "className": "node-card node-card--tf-end",
          "items": [
            {
              "type": "flex",
              "className": "node-header",
              "items": [
                {
                  "type": "container",
                  "className": "node-icon node-icon--tf-end",
                  "body": [{ "type": "icon", "icon": "stop-circle" }]
                },
                {
                  "type": "container",
                  "className": "node-info",
                  "bodyClassName": "flex flex-col gap-0",
                  "body": [
                    {
                      "type": "text",
                      "text": "${step.common.displayName || step.common.name || 'End'}",
                      "className": "node-title"
                    },
                    {
                      "type": "text",
                      "text": "Process exit point",
                      "className": "node-subtitle"
                    }
                  ]
                }
              ]
            },
            {
              "type": "flex",
              "className": "node-footer",
              "items": [
                {
                  "type": "text",
                  "body": "End",
                  "className": "node-badge node-badge--tf-end"
                },
                {
                  "type": "text",
                  "text": "No output",
                  "className": "node-subtitle"
                }
              ]
            }
          ]
        },
        "ports": [
          {
            "id": "in",
            "direction": "input",
            "position": "left",
            "label": "in",
            "maxConnections": "unlimited"
          }
        ],
        "inspector": {
          "body": {
            "type": "form",
            "body": [{ "type": "input-text", "name": "step.common.name", "label": "Name" }]
          }
        }
      },
      {
        "id": "tf-script",
        "label": "Script",
        "icon": "code",
        "description": "Run a script step",
        "appearance": { "minWidth": 192, "minHeight": 112 },
        "defaults": {
          "step": { "common": { "name": "script" }, "props": { "type": "script", "lang": "js" } }
        },
        "body": {
          "type": "flex",
          "direction": "column",
          "className": "node-card node-card--tf-script",
          "items": [
            {
              "type": "flex",
              "className": "node-header",
              "items": [
                {
                  "type": "container",
                  "className": "node-icon node-icon--tf-script",
                  "body": [{ "type": "icon", "icon": "code" }]
                },
                {
                  "type": "container",
                  "className": "node-info",
                  "bodyClassName": "flex flex-col gap-0",
                  "body": [
                    {
                      "type": "text",
                      "text": "${step.common.displayName || step.common.name}",
                      "className": "node-title"
                    },
                    {
                      "type": "text",
                      "text": "${step.props.lang || 'js'} · ${(step.props.source || '').substring(0, 20)}",
                      "className": "node-subtitle"
                    }
                  ]
                }
              ]
            },
            {
              "type": "flex",
              "className": "node-footer",
              "items": [
                {
                  "type": "text",
                  "body": "Script",
                  "className": "node-badge node-badge--tf-script"
                },
                {
                  "type": "text",
                  "text": "${step.props.lang || 'js'}",
                  "className": "node-subtitle"
                }
              ]
            }
          ]
        },
        "ports": [
          {
            "id": "in",
            "direction": "input",
            "position": "left",
            "label": "in",
            "maxConnections": "unlimited"
          },
          {
            "id": "next",
            "direction": "output",
            "position": "right",
            "label": "next",
            "maxConnections": 1
          },
          {
            "id": "error",
            "direction": "output",
            "position": "bottom",
            "label": "error",
            "maxConnections": 1
          },
          {
            "id": "wait",
            "direction": "output",
            "position": "top",
            "label": "wait",
            "maxConnections": "unlimited"
          },
          {
            "id": "wait-error",
            "direction": "output",
            "position": "left",
            "label": "wait-error",
            "maxConnections": "unlimited"
          }
        ],
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.common.displayName", "label": "Display Name" },
              {
                "type": "select",
                "name": "step.props.lang",
                "label": "Language",
                "options": {
                  "values": [
                    { "label": "JavaScript", "value": "js" },
                    { "label": "XPL", "value": "xpl" }
                  ]
                }
              },
              {
                "type": "input-text",
                "name": "step.props.source",
                "label": "Source",
                "type": "textarea"
              }
            ]
          }
        }
      },
      {
        "id": "tf-invoke",
        "label": "Invoke",
        "icon": "zap",
        "description": "Invoke a bean method",
        "appearance": { "minWidth": 192, "minHeight": 112 },
        "defaults": {
          "step": {
            "common": { "name": "invoke" },
            "props": { "type": "invoke", "bean": "", "method": "" }
