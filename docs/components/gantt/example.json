{
  "type": "gantt",
  "defaultZoom": "week",
  "initiallyExpanded": true,
  "draggable": true,
  "editable": true,
  "linkable": true,
  "showWeekends": true,
  "showToday": true,
  "columns": [
    {
      "name": "text",
      "label": "任务名称",
      "width": 240,
      "fixed": "left"
    },
    {
      "name": "assignee",
      "label": "负责人",
      "width": 100
    },
    {
      "name": "progress",
      "label": "进度",
      "width": 80,
      "align": "center"
    }
  ],
  "scales": [
    {
      "unit": "day",
      "step": 1,
      "format": "%d"
    },
    {
      "unit": "month",
      "format": "%Y/%m"
    }
  ],
  "zoomLevels": [
    {
      "key": "day",
      "label": "日",
      "minCellWidth": 40,
      "maxCellWidth": 80,
      "scales": [
        { "unit": "hour", "step": 6, "format": "%H:00" },
        { "unit": "day", "format": "%m/%d" }
      ]
    },
    {
      "key": "week",
      "label": "周",
      "minCellWidth": 20,
      "maxCellWidth": 50,
      "scales": [
        { "unit": "day", "step": 1, "format": "%d" },
        { "unit": "week", "format": "第%W周" }
      ]
    },
    {
      "key": "month",
      "label": "月",
      "minCellWidth": 15,
      "maxCellWidth": 40,
      "scales": [
        { "unit": "week", "step": 1, "format": "W%W" },
        { "unit": "month", "format": "%Y/%m" }
      ]
    }
  ],
  "tasks": [
