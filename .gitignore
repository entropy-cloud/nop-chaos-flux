# Prevent TypeScript build artifacts from leaking into src/ directories.
# All compiled output must go to dist/ via tsconfig.build.json (outDir: "dist").
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
