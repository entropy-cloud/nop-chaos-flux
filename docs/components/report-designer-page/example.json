{
  "type": "report-designer-page",
  "title": "报表设计器",
  "document": {
    "id": "report-demo",
    "kind": "report-template",
    "name": "月度销售报表",
    "version": "1.0.0",
    "spreadsheet": {
      "id": "sheet-demo",
      "kind": "spreadsheet",
      "name": "月度销售报表",
      "version": "1.0.0",
      "workbook": {
        "sheets": [
          {
            "id": "sheet-1",
            "name": "Sheet1",
            "order": 0,
            "cells": {
              "A1": {
                "address": "A1",
                "row": 0,
                "col": 0,
                "value": "产品"
              },
              "B1": {
                "address": "B1",
                "row": 0,
                "col": 1,
                "value": "金额"
              }
            }
          }
        ]
      }
    },
    "semantic": {
      "workbookMeta": {},
      "sheetMeta": {},
      "cellMeta": {},
      "rangeMeta": {}
    }
  },
  "designer": {
    "kind": "nop-report",
    "fieldSources": [
      {
        "id": "sales",
        "label": "销售数据",
        "groups": [
          {
            "id": "base",
            "label": "基础字段",
            "expanded": true,
            "fields": [
              {
                "id": "product",
                "label": "产品",
                "path": "product"
              },
              {
                "id": "amount",
                "label": "金额",
                "path": "amount"
              }
            ]
          }
        ]
      }
    ],
    "inspector": {
      "providers": [
        {
          "id": "cell-style",
          "label": "单元格样式",
          "match": {
            "kinds": ["cell", "range"]
          },
          "body": {
            "type": "form",
            "body": [
              {
                "type": "input-text",
                "name": "format",
                "label": "显示格式"
              }
            ]
          }
        }
      ]
    }
  },
  "toolbar": {
    "type": "report-toolbar"
  },
  "fieldPanel": {
    "type": "report-field-panel",
    "title": "字段"
  },
  "inspector": {
    "type": "report-inspector",
    "emptyLabel": "暂无属性面板",
    "noSelectionLabel": "请选择对象"
  }
}
