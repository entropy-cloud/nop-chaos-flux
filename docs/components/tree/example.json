{
  "type": "tree",
  "data": "${fileTree}",
  "initiallyExpanded": true,
  "searchable": true,
  "showIcon": true,
  "iconField": "icon",
  "showGuideLine": true,
  "node": [
    {
      "type": "text",
      "text": "${node.label}"
    }
  ],
  "empty": {
    "type": "text",
    "text": "No files"
  }
}
