{
  "example": "amis-crud-to-flux-crud",
  "sourceAmis": {
    "type": "crud",
    "api": "/api/users",
    "filter": {
      "title": "查询条件",
      "body": [
        {
          "type": "input-text",
          "name": "keywords",
          "label": "关键字"
        },
        {
          "type": "select",
          "name": "status",
          "label": "状态",
          "multiple": true,
          "options": [
            { "label": "启用", "value": "active" },
            { "label": "禁用", "value": "disabled" }
          ]
        }
      ]
    },
    "headerToolbar": [
      {
        "type": "columns-toggler",
        "draggable": true,
        "align": "right"
      },
      "bulkActions",
      "pagination"
    ],
    "footerToolbar": [
      "statistics",
      "switch-per-page",
      "pagination"
    ],
    "bulkActions": [
      {
        "label": "批量删除",
        "type": "button",
        "actionType": "ajax",
        "api": "delete:/api/users/${ids|raw}"
      }
    ],
    "primaryField": "id",
    "pageField": "pageNo",
    "perPageField": "pageSize",
    "keepItemSelectionOnPageChange": true,
    "maxKeepItemSelectionLength": 20,
    "columns": [
      {
        "name": "id",
        "label": "ID",
        "fixed": "left"
      },
      {
        "name": "name",
        "label": "姓名",
        "sortable": true,
        "searchable": true,
        "fixed": "left"
      },
      {
        "name": "status",
        "label": "状态",
        "filterable": {
          "searchable": true,
          "options": [
            { "label": "启用", "value": "active" },
            { "label": "禁用", "value": "disabled" }
          ]
        }
      },
      {
        "type": "operation",
        "label": "操作",
        "fixed": "right",
        "buttons": [
          {
            "type": "button",
            "label": "编辑",
            "actionType": "dialog",
            "dialog": {
              "title": "编辑用户",
              "body": {
                "type": "form",
                "body": [
                  { "type": "input-text", "name": "name", "label": "姓名" }
                ]
              }
            }
          }
        ]
      }
    ]
  },
  "targetFlux": {
    "type": "crud",
    "id": "users-crud",
    "source": "${users}",
    "queryForm": {
      "layout": "inline",
      "body": [
        {
          "type": "input-text",
          "name": "keywords",
          "label": "关键字"
        },
        {
          "type": "select",
          "name": "status",
          "label": "状态",
          "multiple": true,
          "options": [
            { "label": "启用", "value": "active" },
            { "label": "禁用", "value": "disabled" }
          ]
        }
      ]
    },
    "columnSettings": {
      "enabled": true
    },
    "toolbarLayout": {
      "header": ["listActions", "pagination"],
      "footer": ["statistics", "switch-per-page"]
    },
    "toolbar": [
      {
        "type": "button",
        "label": "刷新",
        "onClick": {
          "action": "component:refresh",
          "componentId": "users-crud"
        }
      }
    ],
    "footerToolbar": [
      {
        "type": "text",
        "text": "共 ${$crud.total || $crud.itemCount} 条"
      }
    ],
    "listActions": [
      {
        "type": "button",
        "label": "批量删除",
        "disabled": "${!$crud.hasSelection}",
        "onClick": {
          "action": "ajax",
          "args": {
            "url": "/api/users",
            "method": "delete",
            "data": {
              "ids": "${$crud.selectedRowKeys}"
            }
          }
        }
      }
    ],
    "rowKey": "id",
    "pageField": "pageNo",
    "pageSizeField": "pageSize",
    "selection": {
      "type": "checkbox"
    },
    "columns": [
      {
        "name": "id",
        "label": "ID",
        "width": 80,
        "fixed": "left"
      },
      {
        "name": "name",
        "label": "姓名",
        "sortable": true,
        "width": 180,
        "fixed": "left"
      },
      {
        "name": "status",
        "label": "状态",
        "width": 140
      },
      {
        "type": "operation",
        "label": "操作",
        "fixed": "right",
        "width": 180,
        "buttons": [
          {
            "type": "button",
            "label": "编辑",
            "onClick": {
              "action": "openDialog",
              "args": {
                "title": "编辑用户",
                "body": {
                  "type": "form",
                  "body": [
                    { "type": "input-text", "name": "name", "label": "姓名" }
                  ]
                }
              }
            }
          }
        ]
      }
    ],
    "migrationHints": {
      "amisApi": "/api/users",
      "notes": [
        "headerToolbar 中的动作块被拆分为 toolbar region 与 toolbarLayout 标准块，bulkActions 降为 listActions",
        "columns-toggler / columnsTogglable 迁移为 columnSettings；当前 live baseline 已支持列显隐和最小上下移动顺序调整",
        "primaryField 迁移为 rowKey",
        "perPageField 迁移为 pageSizeField",
        "filter 迁移为 queryForm",
        "actionType/dialog 迁移为 Flux action/openDialog",
        "api -> source 是 canonical authoring 目标；当前 live baseline 已支持 CRUD 消费上游 source-result object（如 { items, total }）并通过 onRefresh / onQuerySubmit 与上游 source owner 协作",
        "loadDataOnce / loadDataOnceFetchOnFilter 迁移为 clientMode.loadDataOnce / clientMode.fetchOnFilter；syncLocation 与 matchFunc 仍属后续 deferred 范围"
      ]
    }
  }
}
