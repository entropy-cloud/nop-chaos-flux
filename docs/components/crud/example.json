{
  "type": "crud",
  "id": "users-crud",
  "name": "usersCrud",
  "statusPath": "usersCrudStatus",
  "rowKey": "id",
  "selectionOwnership": "scope",
  "selectionStatePath": "usersCrud.selection",
  "paginationOwnership": "scope",
  "paginationStatePath": "usersCrud.pagination",
  "sortOwnership": "scope",
  "sortStatePath": "usersCrud.sort",
  "filterOwnership": "scope",
  "filterStatePath": "usersCrud.filters",
  "syncLocation": false,
  "pageField": "pageNo",
  "pageSizeField": "pageSize",
  "selection": {
    "type": "checkbox"
  },
  "queryForm": {
    "layout": "inline",
    "data": {
      "keywords": "",
      "status": []
    },
    "body": [
      {
        "type": "input-text",
        "name": "keywords",
        "label": "关键字",
        "placeholder": "姓名 / 邮箱"
      },
      {
        "type": "select",
        "name": "status",
        "label": "状态",
        "multiple": true,
        "options": [
          { "label": "启用", "value": "active" },
          { "label": "禁用", "value": "disabled" },
          { "label": "草稿", "value": "draft" }
        ]
      }
    ]
  },
  "columnSettings": {
    "enabled": true,
    "toggledColumnsStatePath": "usersCrud.visibleColumns",
    "orderedColumnsStatePath": "usersCrud.orderedColumns"
  },
  "toolbarLayout": {
    "header": ["listActions", "pagination"],
    "footer": ["statistics", "switch-per-page"]
  },
  "toolbar": [
    {
      "type": "button",
      "label": "新增用户",
      "variant": "default",
      "onClick": {
        "action": "openDialog",
        "args": {
          "title": "新增用户",
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "name", "label": "姓名" },
              { "type": "input-email", "name": "email", "label": "邮箱" }
            ],
            "submitAction": {
              "action": "ajax",
              "args": {
                "url": "/api/users",
                "method": "post",
                "data": "${$form.values}"
              }
            },
            "onSubmitSuccess": {
              "action": "component:refresh",
              "componentId": "users-crud"
            }
          }
        }
      }
    },
    {
      "type": "button",
      "label": "刷新",
      "variant": "outline",
      "onClick": {
        "action": "component:refresh",
        "componentId": "users-crud"
      }
    }
  ],
  "footerToolbar": [
    {
      "type": "text",
      "text": "Query=${$crud.query.keywords || \"none\"}，共 ${$crud.total || $crud.itemCount} 条"
    }
  ],
  "listActions": [
    {
      "type": "button",
      "label": "批量删除",
      "variant": "destructive",
      "disabled": "${!$crud.hasSelection}",
      "onClick": {
        "action": "ajax",
        "args": {
          "url": "/api/users/bulk-delete",
          "method": "post",
          "data": {
            "ids": "${$crud.selectedRowKeys}"
          }
        },
        "then": {
          "action": "component:refresh",
          "componentId": "users-crud"
        }
      }
    }
  ],
  "defaultParams": {
    "keywords": "",
    "status": []
  },
  "source": "${users}",
  "columns": [
    {
      "name": "id",
      "label": "ID",
      "width": 80,
      "fixed": "left"
    },
    {
      "name": "name",
      "label": "姓名",
      "sortable": true,
      "width": 180,
      "fixed": "left"
    },
    {
      "name": "status",
      "label": "状态",
      "width": 140
    },
    {
      "name": "department",
      "label": "部门"
    },
    {
      "type": "operation",
      "label": "操作",
      "fixed": "right",
      "width": 180,
      "buttons": [
        {
          "type": "button",
          "label": "查看",
          "variant": "ghost"
        },
        {
          "type": "button",
          "label": "编辑",
          "variant": "ghost"
        },
        {
          "type": "button",
          "label": "删除",
          "variant": "ghost"
        }
      ]
    }
  ],
  "empty": "暂无用户数据"
}
