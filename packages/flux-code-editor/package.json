{
  "name": "@nop-chaos/flux-code-editor",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./code-editor-styles.css": {
      "default": "./dist/code-editor-styles.css"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.1",
    "@nop-chaos/flux-core": "workspace:*",
    "@nop-chaos/flux-formula": "workspace:*",
    "@nop-chaos/flux-i18n": "workspace:*",
    "@nop-chaos/flux-react": "workspace:*",
    "@nop-chaos/ui": "workspace:*",
    "sql-formatter": "^15.7.3"
  },
  "peerDependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@nop-chaos/flux-renderers-basic": "workspace:*",
    "@nop-chaos/flux-renderers-data": "workspace:*",
    "@nop-chaos/flux-renderers-form": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/copy-build-assets.mjs src/code-editor-styles.css dist/code-editor-styles.css",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location node_modules/.cache/eslint"
  }
}
