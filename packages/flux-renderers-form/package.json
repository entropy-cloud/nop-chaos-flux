{
  "name": "@nop-chaos/flux-renderers-form",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./form-renderers.css": {
      "default": "./dist/form-renderers.css"
    },
    "./test-support": {
      "types": "./dist/test-support.d.ts",
      "default": "./dist/test-support.js"
    }
  },
  "dependencies": {
    "@nop-chaos/flux-core": "workspace:*",
    "@nop-chaos/flux-i18n": "workspace:*",
    "@nop-chaos/flux-react": "workspace:*",
    "@nop-chaos/flux-runtime": "workspace:*",
    "@nop-chaos/ui": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"fs.cpSync('src/form-renderers.css','dist/form-renderers.css')\"",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location node_modules/.cache/eslint"
  },
  "devDependencies": {
    "@nop-chaos/flux-compiler": "workspace:*",
    "@nop-chaos/flux-formula": "workspace:*",
    "@nop-chaos/flux-renderers-basic": "workspace:*"
  }
}
