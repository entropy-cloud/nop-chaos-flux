              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.props.delayMillisExpr", "label": "Delay (ms)" }
            ]
          }
        }
      }
    ],
    "edgeTypes": [
      {
        "id": "tf-next",
        "label": "Next",
        "appearance": { "stroke": "#6366f1", "strokeWidth": 2, "markerEnd": "arrow" },
        "defaults": { "taskflowEdgeKind": "taskflow-next" },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "data.taskflowEdgeKind", "label": "Edge Kind" },
              { "type": "input-text", "name": "data.label", "label": "Label" }
            ]
          }
        }
      },
      {
        "id": "tf-error",
        "label": "Error",
        "appearance": {
          "stroke": "#ef4444",
          "strokeWidth": 2,
          "strokeStyle": "dashed",
          "markerEnd": "arrow"
        },
        "defaults": { "taskflowEdgeKind": "taskflow-error" },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "data.taskflowEdgeKind", "label": "Edge Kind" },
              { "type": "input-text", "name": "data.label", "label": "Label" }
            ]
          }
        }
      },
      {
        "id": "tf-wait",
        "label": "Wait",
        "appearance": {
          "stroke": "#22c55e",
          "strokeWidth": 2,
          "strokeStyle": "dotted",
          "markerEnd": "arrow"
        },
        "defaults": { "taskflowEdgeKind": "taskflow-wait" },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "data.taskflowEdgeKind", "label": "Edge Kind" },
              { "type": "input-text", "name": "data.label", "label": "Label" }
            ]
          }
        }
      },
      {
        "id": "tf-wait-error",
        "label": "Wait Error",
        "appearance": {
          "stroke": "#f97316",
          "strokeWidth": 2,
          "strokeStyle": "dashed",
          "markerEnd": "arrow"
        },
        "defaults": { "taskflowEdgeKind": "taskflow-wait-error" },
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "data.taskflowEdgeKind", "label": "Edge Kind" },
              { "type": "input-text", "name": "data.label", "label": "Label" }
            ]
          }
        }
      }
    ],
    "palette": {
      "searchable": true,
      "groups": [
        { "id": "control", "label": "Control", "nodeTypes": ["tf-start", "tf-end"] },
        {
          "id": "execution",
          "label": "Execution",
          "nodeTypes": ["tf-script", "tf-invoke", "tf-delay"]
        },
        { "id": "logic", "label": "Logic", "nodeTypes": ["tf-if", "tf-choose"] },
        {
          "id": "containers",
          "label": "Containers",
          "nodeTypes": ["tf-sequential", "tf-graph", "tf-parallel"]
        }
      ]
    },
    "toolbar": {
      "items": [
        { "type": "title", "body": "TaskFlow (Graph)" },
        { "type": "text", "text": "Container: ${doc.name}" },
        { "type": "spacer" },
        {
          "type": "button",
          "action": "taskflow:exit-container",
          "label": "Back",
          "icon": "arrow-left"
        },
        {
          "type": "button",
          "action": "taskflow:export-json",
          "label": "Export",
          "icon": "download"
        },
        { "type": "button", "action": "taskflow:import-json", "label": "Import", "icon": "upload" },
        { "type": "button", "action": "taskflow:save", "label": "Save", "icon": "save" },
        { "type": "button", "action": "designer:undo", "label": "Undo", "icon": "undo" },
        { "type": "button", "action": "designer:redo", "label": "Redo", "icon": "redo" }
      ]
    },
    "features": {
      "undo": true,
      "redo": true,
      "grid": true,
      "minimap": true,
      "export": false,
      "clipboard": true
    },
    "rules": { "allowMultiEdge": true, "defaultEdgeType": "tf-next" },
    "canvas": {
      "background": "dots",
      "gridSize": 20,
      "snapToGrid": true,
      "minZoom": 0.25,
      "maxZoom": 4
    }
  }
}
