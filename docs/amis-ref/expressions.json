{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ExpressionValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/ExpressionSimple"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "value"
            },
            "value": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "object"
                }
              ]
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        }
      ]
    },
    "ExpressionFormula": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "formula"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "value"
      ],
      "additionalProperties": false
    },
    "ExpressionField": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "field"
        },
        "field": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "field"
      ],
      "additionalProperties": false
    },
    "ExpressionFunc": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "func"
        },
        "func": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExpressionComplex"
          }
        }
      },
      "required": [
        "type",
        "func",
        "args"
      ],
      "additionalProperties": false
    },
    "ExpressionSimple": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "object"
        },
        {
          "not": {}
        }
      ]
    },
    "ExpressionComplex": {
      "anyOf": [
        {
          "$ref": "#/definitions/ExpressionValue"
        },
        {
          "$ref": "#/definitions/ExpressionFunc"
        },
        {
          "$ref": "#/definitions/ExpressionField"
        },
        {
          "$ref": "#/definitions/ExpressionFormula"
        }
      ]
    }
  }
}