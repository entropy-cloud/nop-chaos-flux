{
  "type": "crud",
  "id": "users-crud",
  "name": "usersCrud",
  "statusPath": "usersCrudStatus",
  "paginationOwnership": "scope",
  "paginationStatePath": "usersTablePagination",
  "selectionOwnership": "scope",
  "selectionStatePath": "usersTableSelection",
  "sortOwnership": "scope",
  "sortStatePath": "usersTableSort",
  "filterOwnership": "scope",
  "filterStatePath": "usersTableFilter",
  "rowKey": "id",
  "autoClearSelectionOnRefresh": true,
  "queryForm": {
    "data": {
      "keyword": "",
      "status": "all"
    },
    "body": [
      {
        "type": "input-text",
        "name": "keyword",
        "label": "关键字",
        "placeholder": "姓名 / 邮箱"
      },
      {
        "type": "select",
        "name": "status",
        "label": "状态",
        "options": [
          { "label": "全部", "value": "all" },
          { "label": "启用", "value": "active" },
          { "label": "禁用", "value": "disabled" }
        ]
      }
    ],
    "actions": [
      {
        "type": "button",
        "label": "查询",
        "variant": "primary",
        "onClick": {
          "action": "component:submit",
          "componentId": "users-crud"
        }
      },
      {
        "type": "button",
        "label": "重置",
        "variant": "outline",
        "onClick": {
          "action": "component:clearSelection",
          "componentId": "users-crud"
        }
      }
    ]
  },
  "source": {
    "type": "source",
    "action": "ajax",
    "api": {
      "url": "/api/users",
      "method": "get",
      "params": {
        "keyword": "${query.keyword}",
        "status": "${query.status}",
        "page": "${pagination.currentPage}",
        "pageSize": "${pagination.pageSize}",
        "sortField": "${sort.field}",
        "sortOrder": "${sort.order}"
      },
      "responseAdaptor": "${{ items: payload.items, total: payload.total, page: payload.page, pageSize: payload.pageSize }}"
    }
  },
  "toolbar": [
    {
      "type": "button",
      "label": "新增用户",
      "variant": "primary",
      "onClick": {
        "action": "openDialog",
        "args": {
          "title": "新增用户",
          "size": "lg",
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "name", "label": "姓名" },
              { "type": "input-email", "name": "email", "label": "邮箱" }
            ],
            "submitAction": {
              "action": "ajax",
              "args": {
                "url": "/api/users",
                "method": "post",
                "data": "${$form.values}"
              }
            },
            "onSubmitSuccess": {
              "action": "component:refresh",
              "componentId": "users-crud"
            }
          }
        }
      }
    },
    {
      "type": "button",
      "label": "刷新",
      "variant": "outline",
      "onClick": {
        "action": "component:refresh",
        "componentId": "users-crud"
      }
    }
  ],
  "bulkActions": [
    {
      "type": "button",
      "label": "批量删除",
      "variant": "danger",
      "disabled": "${!$crud.hasSelection}",
      "onClick": {
        "action": "ajax",
        "args": {
          "url": "/api/users/bulk-delete",
          "method": "post",
          "data": { "ids": "${$crud.selectedRowKeys}" }
        },
        "then": {
          "action": "component:refresh",
          "componentId": "users-crud"
        }
      }
    }
  ],
  "columns": [
    { "name": "name", "label": "姓名", "sortable": true },
    { "name": "email", "label": "邮箱" },
    {
      "name": "status",
      "label": "状态",
      "filterable": true,
      "filterOptions": [
        { "label": "启用", "value": "active" },
        { "label": "禁用", "value": "disabled" }
      ]
    },
    {
      "type": "operation",
      "label": "操作",
      "buttons": [
        {
          "type": "button",
          "label": "查看",
          "variant": "ghost",
          "onClick": {
            "action": "openDialog",
            "args": {
              "title": "用户详情",
              "size": "lg",
              "body": [
                { "type": "text", "text": "姓名: ${record.name}" },
                { "type": "text", "text": "邮箱: ${record.email}" },
                { "type": "text", "text": "状态: ${record.status}" }
              ]
            }
          }
        },
        {
          "type": "button",
          "label": "编辑",
          "variant": "ghost",
          "onClick": {
            "action": "openDialog",
            "args": {
              "title": "编辑用户",
              "size": "lg",
              "body": {
                "type": "form",
                "data": "${record}",
                "body": [
                  { "type": "input-text", "name": "name", "label": "姓名" },
                  { "type": "input-email", "name": "email", "label": "邮箱" }
                ],
                "submitAction": {
                  "action": "ajax",
                  "args": {
                    "url": "/api/users/${record.id}",
                    "method": "put",
                    "data": "${$form.values}"
                  }
                },
                "onSubmitSuccess": {
                  "action": "component:refresh",
                  "componentId": "users-crud"
                }
              }
            }
          }
        },
        {
          "type": "button",
          "label": "删除",
          "variant": "ghost",
          "onClick": {
            "action": "ajax",
            "args": {
              "url": "/api/users/${record.id}",
              "method": "delete"
            },
            "then": {
              "action": "component:refresh",
              "componentId": "users-crud"
            }
          }
        }
      ]
    }
  ],
  "empty": "暂无用户数据"
}
