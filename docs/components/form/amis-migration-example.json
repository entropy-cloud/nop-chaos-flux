              }
            ]
          },
          {
            "type": "input-email",
            "name": "email",
            "label": "邮箱",
            "required": true,
            "description": "用于接收系统通知",
            "remark": {
              "content": "请使用公司邮箱"
            }
          },
          {
            "type": "input-password",
            "name": "password",
            "label": "密码",
            "required": true,
            "hint": "至少8位，包含字母和数字",
            "labelRemark": {
              "content": "密码强度要求：至少8位"
            }
          }
        ]
      },
      {
        "type": "fieldset",
        "title": "联系方式",
        "collapsible": true,
        "collapsed": true,
        "body": [
          {
            "type": "input-text",
            "name": "phone",
            "label": "手机号",
            "description": "11位手机号码",
            "mode": "normal"
          },
          {
            "type": "input-text",
