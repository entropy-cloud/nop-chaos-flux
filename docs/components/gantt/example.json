  "onTaskClick": {
    "action": "showToast",
    "args": {
      "level": "info",
      "message": "点击任务: ${event.taskId}"
    }
  },
  "onTaskDoubleClick": {
    "action": "showToast",
    "args": {
      "level": "info",
      "message": "双击任务: ${event.taskId}"
    }
  },
  "onTaskDragEnd": {
    "action": "showToast",
    "args": {
      "level": "success",
      "message": "任务 ${event.taskId} 已更新"
    }
  },
  "zoomIn": {
    "action": "zoomIn"
  },
  "zoomOut": {
    "action": "zoomOut"
  },
  "scrollToToday": {
    "action": "scrollToToday"
  },
  "taskBar": [
    {
      "type": "text",
      "text": "${task.text}"
    }
  ],
  "empty": "暂无排程数据"
