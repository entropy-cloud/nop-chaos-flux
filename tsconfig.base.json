{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@nop-chaos/amis-schema": ["packages/amis-schema/src/index.ts"],
      "@nop-chaos/amis-formula": ["packages/amis-formula/src/index.ts"],
      "@nop-chaos/amis-runtime": ["packages/amis-runtime/src/index.ts"],
      "@nop-chaos/amis-react": ["packages/amis-react/src/index.tsx"],
      "@nop-chaos/amis-renderers-basic": ["packages/amis-renderers-basic/src/index.tsx"],
      "@nop-chaos/amis-renderers-form": ["packages/amis-renderers-form/src/index.tsx"],
      "@nop-chaos/amis-renderers-data": ["packages/amis-renderers-data/src/index.tsx"],
      "@nop-chaos/amis-testing": ["packages/amis-testing/src/index.ts"]
    }
  }
}
