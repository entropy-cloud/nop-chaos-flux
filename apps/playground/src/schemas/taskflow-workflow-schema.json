{
  "type": "designer-page",
  "xui:imports": [{ "from": "taskflow-designer", "as": "taskflow" }],
  "document": {
    "id": "tf-workflow-demo",
    "kind": "nop-taskflow-workflow",
    "name": "TaskFlow Workflow Demo",
    "version": "1.0",
    "viewport": { "x": 0, "y": 0, "zoom": 1 },
    "nodes": [
      {
        "id": "start-1",
        "type": "tf-start",
        "position": { "x": 50, "y": 200 },
        "data": {
          "step": {
            "id": "start-1",
            "type": "script",
            "common": { "name": "start" },
            "props": { "type": "script", "lang": "js", "source": "// init" }
          }
        }
      },
      {
        "id": "script-1",
        "type": "tf-script",
        "position": { "x": 250, "y": 200 },
        "data": {
          "step": {
            "id": "script-1",
            "type": "script",
            "common": { "name": "validateInput" },
            "props": { "type": "script", "lang": "js", "source": "// validate" }
          }
        }
      },
      {
        "id": "invoke-1",
        "type": "tf-invoke",
        "position": { "x": 450, "y": 200 },
        "data": {
          "step": {
            "id": "invoke-1",
            "type": "invoke",
            "common": { "name": "processOrder" },
            "props": { "type": "invoke", "bean": "orderService", "method": "process" }
          }
        }
      },
      {
        "id": "if-1",
        "type": "tf-if",
        "position": { "x": 650, "y": 200 },
        "data": {
          "step": {
            "id": "if-1",
            "type": "if",
            "common": { "name": "checkStatus" },
            "props": { "type": "if", "condition": "${status == 'ok'}" }
          }
        }
      },
      {
        "id": "delay-1",
        "type": "tf-delay",
        "position": { "x": 650, "y": 400 },
        "data": {
          "step": {
            "id": "delay-1",
            "type": "delay",
            "common": { "name": "waitBeforeRetry" },
            "props": { "type": "delay", "delayMillisExpr": "5000" }
          }
        }
      },
      {
        "id": "end-1",
        "type": "tf-end",
        "position": { "x": 850, "y": 200 },
        "data": {
          "step": {
            "id": "end-1",
            "type": "script",
            "common": { "name": "complete" },
            "props": { "type": "script", "lang": "js", "source": "// done" }
          }
        }
      },
      {
        "id": "graph-1",
        "type": "tf-graph",
        "position": { "x": 250, "y": 400 },
        "data": {
          "step": {
            "id": "graph-1",
            "type": "graph",
            "common": { "name": "subGraph" },
            "props": { "type": "graph" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "type": "tf-next",
        "source": "start-1",
        "target": "script-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e2",
        "type": "tf-next",
        "source": "script-1",
        "target": "invoke-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e3",
        "type": "tf-next",
        "source": "invoke-1",
        "target": "if-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e4",
        "type": "tf-error",
        "source": "invoke-1",
        "target": "delay-1",
        "sourcePort": "error",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-error", "label": "error" }
      },
      {
        "id": "e5",
        "type": "tf-next",
        "source": "if-1",
        "target": "end-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "next" }
      },
      {
        "id": "e6",
        "type": "tf-wait",
        "source": "script-1",
        "target": "graph-1",
        "sourcePort": "wait",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-wait", "label": "wait" }
      },
      {
        "id": "e7",
        "type": "tf-wait-error",
        "source": "invoke-1",
        "target": "graph-1",
        "sourcePort": "wait-error",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-wait-error", "label": "wait-error" }
      },
      {
        "id": "e8",
        "type": "tf-next",
        "source": "delay-1",
        "target": "invoke-1",
        "sourcePort": "next",
        "targetPort": "in",
        "data": { "taskflowEdgeKind": "taskflow-next", "label": "retry" }
      }
    ]
  },
  "config": {
    "version": "1.0",
    "kind": "nop-taskflow-workflow",
    "documentMode": "graph",
    "nodeTypes": [
      {
        "id": "tf-start",
        "label": "Start",
        "icon": "play-circle",
        "description": "Workflow start node",
        "constraints": { "maxInstances": 1, "allowIncoming": false },
        "defaults": { "step": { "common": { "name": "start" } } },
        "appearance": { "minWidth": 100, "minHeight": 40, "borderRadius": 20 },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "play-circle", "className": "text-green-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name}" }
          ]
        },
        "ports": [
          {
            "id": "next",
            "direction": "output",
            "position": "right",
            "label": "next",
            "maxConnections": 1
          },
          {
            "id": "error",
            "direction": "output",
            "position": "bottom",
            "label": "error",
            "maxConnections": 1
          },
          {
            "id": "wait",
            "direction": "output",
            "position": "top",
            "label": "wait",
            "maxConnections": "unlimited"
          },
          {
            "id": "wait-error",
            "direction": "output",
            "position": "left",
            "label": "wait-error",
            "maxConnections": "unlimited"
          }
        ],
        "inspector": {
          "body": {
            "type": "form",
            "body": [
              { "type": "input-text", "name": "step.common.name", "label": "Name" },
              { "type": "input-text", "name": "step.common.displayName", "label": "Display Name" },
              { "type": "input-text", "name": "step.props.source", "label": "Source" }
            ]
          }
        }
      },
      {
        "id": "tf-end",
        "label": "End",
        "icon": "stop-circle",
        "description": "Workflow end node",
        "constraints": { "maxInstances": 1, "allowOutgoing": false },
        "defaults": {},
        "appearance": { "minWidth": 100, "minHeight": 40, "borderRadius": 20 },
        "body": {
          "type": "flex",
          "className": "items-center gap-2 px-3 py-2",
          "body": [
            { "type": "icon", "icon": "stop-circle", "className": "text-red-500 w-4 h-4" },
            { "type": "text", "text": "${step.common.displayName || step.common.name || 'End'}" }
          ]
        },
        "ports": [
          {
            "id": "in",
            "direction": "input",
            "position": "left",
            "label": "in",
            "maxConnections": "unlimited"
          }
        ],
        "inspector": {
          "body": {
            "type": "form",
            "body": [{ "type": "input-text", "name": "step.common.name", "label": "Name" }]
          }
