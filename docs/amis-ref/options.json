{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "MultipleValue": {
      "type": "object",
      "properties": {
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      },
      "required": [
        "min",
        "max"
      ],
      "additionalProperties": false
    },
    "DataProvider": {
      "type": "string"
    },
    "DataProviderCollection": {
      "type": "object",
      "properties": {
        "inited": {
          "$ref": "#/definitions/DataProvider"
        },
        "onApiFetched": {
          "$ref": "#/definitions/DataProvider"
        },
        "onSchemaApiFetched": {
          "$ref": "#/definitions/DataProvider"
        },
        "onWsFetched": {
          "$ref": "#/definitions/DataProvider"
        }
      },
      "additionalProperties": false
    },
    "Option": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string",
          "description": "用来显示的文字"
        },
        "scopeLabel": {
          "type": "string",
          "description": "可以用来给 Option 标记个范围，让数据展示更清晰。\n\n这个只有在数值展示的时候显示。"
        },
        "value": {
          "description": "请保证数值唯一，多个选项值一致会认为是同一个选项。"
        },
        "disabled": {
          "type": "boolean",
          "description": "是否禁用"
        },
        "disabledTip": {
          "type": "string",
          "description": "禁用提示"
        },
        "children": {
          "$ref": "#/definitions/Options",
          "description": "支持嵌套"
        },
        "visible": {
          "type": "boolean",
          "description": "是否可见"
        },
        "hidden": {
          "type": "boolean",
          "description": "最好不要用！因为有 visible 就够了。",
          "deprecated": "用 visible"
        },
        "description": {
          "type": "string",
          "description": "描述，部分控件支持"
        },
        "defer": {
          "type": "boolean",
          "description": "标记后数据延时加载"
        },
        "deferApi": {
          "$ref": "#/definitions/BaseApi",
          "description": "如果设置了，优先级更高，不设置走 source 接口加载。"
        },
        "loading": {
          "type": "boolean",
          "description": "标记正在加载。只有 defer 为 true 时有意义。内部字段不可以外部设置"
        },
        "loaded": {
          "type": "boolean",
          "description": "只有设置了 defer 才有意义，内部字段不可以外部设置"
        }
      }
    },
    "Options": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Option"
      }
    },
    "ComposedDataProvider": {
      "anyOf": [
        {
          "$ref": "#/definitions/DataProvider"
        },
        {
          "$ref": "#/definitions/DataProviderCollection"
        }
      ]
    }
  }
}