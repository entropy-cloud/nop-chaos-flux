{
  "name": "@nop-chaos/spreadsheet-renderers",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./canvas-styles.css": {
      "default": "./dist/canvas-styles.css"
    }
  },
  "dependencies": {
    "@nop-chaos/spreadsheet-core": "workspace:*",
    "@nop-chaos/flux-formula": "workspace:*",
    "@nop-chaos/flux-runtime": "workspace:*",
    "@nop-chaos/flux-react": "workspace:*",
    "@nop-chaos/flux-core": "workspace:*",
    "@nop-chaos/flux-i18n": "workspace:*",
    "@nop-chaos/ui": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "use-sync-external-store": "^1.6.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"fs.cpSync('src/canvas-styles.css','dist/canvas-styles.css')\"",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location node_modules/.cache/eslint"
  }
}
