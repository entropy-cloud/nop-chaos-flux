{
  "name": "nop-chaos-flux-workspace",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --filter=@nop-chaos/flux-playground",
    "postinstall": "node scripts/patch-lucide-react.mjs",
    "check": "pnpm check:react19 && pnpm check:src-artifacts && pnpm check:oversized-code-files && pnpm check:active-doc-code-anchors && pnpm check:package-css-exports && pnpm check:flux-bundle-pack && pnpm check:i18n-keys && pnpm check:workspace-manifest-deps && pnpm check:schema-prop-coverage && pnpm check:audit-suspects",
    "analyze": "turbo run analyze --filter=@nop-chaos/flux-playground",
    "audit:deps": "depcruise --config .dependency-cruiser.cjs apps packages scripts",
    "audit:knip": "knip --config knip.json",
    "audit:knip:packages": "knip --config knip.json --workspace \"./packages/*\"",
    "audit:knip:playground": "knip --config knip.json --workspace ./apps/playground",
    "audit:mutants": "stryker run stryker.runtime.conf.mjs --plugins @stryker-mutator/vitest-runner",
    "audit:semgrep": "semgrep --config .semgrep.yml .",
    "audit:react-doctor": "npx react-doctor@latest . --verbose -y",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "tsc": "tsgo",
    "tsc6": "tsc6",
    "test": "turbo run test --concurrency=2",
    "test:coverage": "turbo run test --concurrency=2 -- --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "check:react19": "node scripts/check-react19-legacy-apis.mjs",
    "check:oversized-code-files": "node scripts/check-oversized-code-files.mjs",
    "check:active-doc-code-anchors": "node scripts/check-active-doc-code-anchors.mjs",
    "check:docs-garbled": "node scripts/check-docs-garbled.mjs",
    "check:package-css-exports": "node scripts/check-package-css-exports.mjs",
    "check:renderer-definition-fields-only": "node scripts/check-renderer-definition-fields-only.mjs",
    "check:finite-prop-contracts": "node scripts/check-finite-prop-contracts.mjs",
    "check:src-artifacts": "node scripts/verify-no-src-artifacts.mjs",
    "check:i18n-keys": "node scripts/check-i18n-keys.mjs",
    "check:workspace-manifest-deps": "node scripts/check-workspace-manifest-deps.mjs",
    "check:schema-prop-coverage": "node scripts/check-schema-prop-coverage.mjs",
    "check:audit-suspects": "node scripts/audit/discover-audit-suspects.mjs",
    "check:flux-bundle-pack": "node scripts/check-flux-bundle-pack.mjs",
    "check:audit-reactive-render-reads": "node scripts/audit/find-reactive-render-reads.mjs",
    "check:audit-async-failure-paths": "node scripts/audit/find-async-without-failure-path.mjs",
    "check:audit-fieldframe-bypasses": "node scripts/audit/find-fieldframe-bypasses.mjs",
    "check:audit-test-global-leaks": "node scripts/audit/find-test-global-leaks.mjs",
    "check:audit-missing-renderer-markers": "node scripts/audit/find-missing-renderer-markers.mjs",
    "check:audit-performance-suspects": "node scripts/audit/find-performance-suspects.mjs",
    "check:audit-styling-suspects": "node scripts/audit/find-styling-suspects.mjs",
    "check:audit-non-retained-renderer-references": "node scripts/audit/find-non-retained-renderer-references.mjs",
    "check:audit-react19-optimization-candidates": "node scripts/audit/find-react19-optimization-candidates.mjs",
    "check:audit-runtime-raw-schema-reads": "node scripts/audit/find-runtime-raw-schema-reads.mjs",
    "check:audit-hardcoded-type-dispatch": "node scripts/audit/find-hardcoded-type-dispatch.mjs",
    "check:duplicates": "node scripts/check-duplicates.mjs",
    "check:duplicates:detail": "jscpd packages/ --config .jscpd.json",
    "lint": "node scripts/clean-src-artifacts.mjs && node scripts/verify-no-src-artifacts.mjs && node scripts/check-react19-legacy-apis.mjs && node scripts/check-active-doc-code-anchors.mjs && node scripts/check-package-css-exports.mjs && node scripts/check-renderer-definition-fields-only.mjs && node scripts/check-finite-prop-contracts.mjs && node scripts/check-i18n-keys.mjs && node scripts/check-schema-prop-coverage.mjs && turbo run lint",
    "clean:cache": "rimraf --glob .turbo \"packages/*/node_modules/.cache\" \"apps/*/node_modules/.cache\" node_modules/.cache .vite",
    "clean": "pnpm -r exec npx rimraf node_modules dist && npx rimraf node_modules",
    "clean:src-artifacts": "node scripts/clean-src-artifacts.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:flux-bundle": "node scripts/pack-flux-bundle.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@typescript/typescript6": "^6.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.7",
    "i18next": "^26.0.5",
    "jscpd": "^4.0.9",
    "knip": "^6.9.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react-i18next": "^17.0.4",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.9.6",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "cross-env": "^10.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{json,md,css}": "prettier --write"
  }
}
